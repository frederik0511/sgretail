<script>
  function increaseQty(button) {
    const input = button.parentElement.querySelector('.qty-input');
    let current = parseInt(input.value) || 1;
    input.value = current + 1;
  }

  function decreaseQty(button) {
    const input = button.parentElement.querySelector('.qty-input');
    let current = parseInt(input.value) || 1;
    if (current > 1) {
      input.value = current - 1;
    }
  }

  (function(){
    console.log('AJAX add-to-cart: script loaded');

    function showMessage(form, text, isError) {
      let msg = form.querySelector('.ajax-add-message');
      if (!msg) {
        msg = document.createElement('div');
        msg.className = 'ajax-add-message';
        msg.style.cssText = 'margin-top:8px;font-size:13px;';
        form.appendChild(msg);
      }
      msg.textContent = text;
      msg.style.color = isError ? 'red' : 'green';
    }

    function doAjaxAdd(form) {
      console.log('AJAX add-to-cart: intercepted submit for form', form);

      const idInput = form.querySelector('input[name="id"], select[name="id"], input[name="variantId"]');
      const qtyInput = form.querySelector('input[name="quantity"], input.qty-input');

      const variantId = idInput ? idInput.value : null;
      const quantity = qtyInput ? Math.max(1, parseInt(qtyInput.value || '1', 10)) : 1;

      if (!variantId) {
        showMessage(form, 'Variant ID not found in form', true);
        console.error('AJAX add-to-cart: variant id not found', form);
        return Promise.reject(new Error('variant_id_missing'));
      }

      showMessage(form, 'Legger til i handlekurv...', false);

      const params = new URLSearchParams();
      params.append('id', variantId);
      params.append('quantity', quantity);

      return fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json'
        },
        body: params.toString(),
        credentials: 'same-origin'
      })
      .then(function(res){
        if (!res.ok) return res.json().then(function(err){ throw err; });
        return res.json();
      })
      .then(function(data){
        console.log('AJAX add-to-cart: success', data);
        showMessage(form, 'Produkt lagt i handlekurv', false);
        // refresh page to show updated cart
        setTimeout(function(){ location.reload(); }, 600);
        return data;
      })
      .catch(function(err){
        console.error('AJAX add-to-cart: error', err);
        const msg = (err && (err.description || err.message)) || 'Feil ved legging i handlekurv';
        showMessage(form, msg, true);
        throw err;
      });
    }

    // Intercept submit (capture = true to run early)
    document.addEventListener('submit', function(e){
      const form = e.target.closest && e.target.closest('.collection-add-to-cart-form');
      if (!form) return;
      e.preventDefault();
      e.stopImmediatePropagation();
      doAjaxAdd(form).catch(()=>{/* already handled */});
    }, true);

    // Also intercept clicks on add-to-cart button (in case other click handlers redirect before submit event)
    document.addEventListener('click', function(e){
      const btn = e.target.closest && e.target.closest('.add-to-cart-btn');
      if (!btn) return;
      const form = btn.closest && btn.closest('.collection-add-to-cart-form');
      if (!form) return;
      // prevent other click handlers that might redirect
      e.preventDefault();
      e.stopImmediatePropagation();
      doAjaxAdd(form).catch(()=>{/* already handled */});
    }, true);

    // Helpful: notify script attached
    console.log('AJAX add-to-cart: handlers attached (submit + click)');
  })();
</script> {% endcomment %}

