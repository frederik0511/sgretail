  padding: 0;
  margin: 0;
}

.mega-menu-v2__links li {
  margin-bottom: 8px;
}

.mega-menu-v2__links li a {
  font-family: 'Barlow Condensed';
  font-size: 16px;
  color: #4D4D4D;
  font-weight: 500;
  text-decoration: none;
}

/* RIGHT SLIDER */
.mega-slider {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-behavior: smooth;
  scrollbar-width: none;
}

.mega-slider::-webkit-scrollbar {
  display: none;
}

/* Card */
.mega-v2-card {
  flex: 0 0 48%;
  border-radius: 12px;
  overflow: hidden;
}

.mega-v2-card a {
  text-decoration: none;
}

/* Image */
.mega-v2-card__image img {
  width: 100%;
  height: auto;
}

/* Content */
{% comment %} .mega-v2-card__content {
  padding: 20px 0;
