                  <!-- Load jQuery -->
                  {% comment %} <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script> {% endcomment %}

                  <script>
                    $('.quick-info-btn').on('click', function () {
                      const title = $(this).data('title');
                      const image = $(this).data('image');
                      const desc = $(this).data('desc');
                      const price = $(this).data('price');
                      const compare = $(this).data('compare');
                      const variantId = $(this).data('variant');
                      const productUrl = $(this).data('url'); // ✅ Get product URL

                      let priceHTML = '';

                      if (compare && compare !== price) {
                        priceHTML = `
                          <p class="modal-pricing">
                            <span style="text-decoration: line-through; font-size: 20px; font-weight: 700; color: #c8202f;">${compare}</span>
                            <span style="font-size: 20px; font-weight: 700; color: #00514e;">${price}</span>
                          </p>`;
                      } else {
                        priceHTML = `<p class="modal-pricing">${price}</p>`;
                      }
                        $('#modalInnerContent').html(`
                          <div class="img-wrapper" style="position:relative;">
                            <img class="modal-img" src="${image}" alt="${title}" style="border-radius:10px;" />
                          
                          </div>
                          <div class="content-wrapper">
                            <h2 class="modal-heading-1">${title}</h2>
                            <p class="modal-para" style="margin-top: 10px;">${desc}</p>
                            ${priceHTML}

                            

                            <a href="${productUrl}" class="btn btn--primary" style="margin-top: 15px;">View Product</a>
                          </div>
                        `);

                        $('#quickInfoModal').fadeIn();
                      });



  
                        // for quick information modal button
                    document.addEventListener('DOMContentLoaded', function () {
                      document.body.addEventListener('submit', function (e) {
                        const form = e.target;
                        if (!form.matches('.collection-add-to-cart-form')) return;

                        e.preventDefault();

                        const formData = new FormData(form);
                        const button = form.querySelector('.add-to-cart-btn');

                        fetch('/cart/add.js', {
                          method: 'POST',
                          headers: {
                            'Accept': 'application/json'
                          },
                          body: formData
                        })
                        .then((res) => res.json())
                        .then((data) => {
                          console.log('Added:', data);
                          button.textContent = 'Added';
                          button.disabled = true;

                          setTimeout(() => {
                            button.textContent = 'Add To Cart';
                            button.disabled = false;
                          }, 3000);
                        })
                        .catch((err) => {
                          console.error('Add to cart error:', err);
                        });
                      });
                    });


                        // Close button
                      $(document).on('click', '.close-btn', function () {
                      $('#quickInfoModal').fadeOut();
                    });

                  </script>





          </div>
        {%- endif -%}
      </div>
    </div>
