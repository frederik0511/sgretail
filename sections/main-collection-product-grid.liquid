    position: absolute;
    right: 0;
    background-color: #00514E;
    padding: 5px;
    border-radius: 10px;
    bottom: 290px;
}
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const content = document.querySelector(".collection-description-content");
      const toggleBtn = document.querySelector(".collection-description-toggle");

      if (!content || !toggleBtn) return;

      const collapsedHeight = 180;

      // If content is shorter than collapsed height, hide button
      if (content.scrollHeight <= collapsedHeight) {
        toggleBtn.style.display = "none";
        return;
      }

      toggleBtn.addEventListener("click", function () {
        content.classList.toggle("expanded");

        if (content.classList.contains("expanded")) {
          toggleBtn.textContent = "Mindre";
        } else {
          toggleBtn.textContent = "Se mere";
        }
      });
    });

  </script>

