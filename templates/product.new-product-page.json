{"sections":{"custom_liquid_TMzBiR":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"{% comment %}\n  Breadcrumbs Section for Dawn Theme\n{% endcomment %}\n\n{% if template != 'index' and template != 'cart' %}\n<div class=\"breadcrumb-wrapper\">  \n  <nav class=\"breadcrumb\" role=\"navigation\" aria-label=\"breadcrumbs\">\n    <a href=\"{{ routes.root_url }}\" class=\"\">Home<\/a>\n\n    {% if template contains 'collection' and collection %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ collection.title }}<\/span>\n\n    {% elsif template contains 'product' and product %}\n      {% if product.collections.size > 0 %}\n        {% for coll in product.collections %}\n          <span class=\"mx-2\"> > <\/span>\n          <a href=\"{{ coll.url }}\" class=\"\">{{ coll.title }}<\/a>\n        {% endfor %}\n      {% endif %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ product.title }}<\/span>\n\n    {% elsif template contains 'article' and article %}\n      <span class=\"mx-2\"> > <\/span>\n      <a href=\"{{ blog.url }}\" class=\"\">{{ blog.title }}<\/a>\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ article.title }}<\/span>\n\n    {% elsif template contains 'page' and page %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ page.title }}<\/span>\n\n    {% elsif template contains 'search' %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>Search<\/span>\n    {% endif %}\n  <\/nav>\n<p class=\"product-sku\">\n  <strong>SKU:<\/strong> {{ product.selected_or_first_available_variant.sku }}\n<\/p>\n<\/div>\n{% endif %}\n\n\n\n<style>\n  .breadcrumb {\n    font-size: 0.9rem;\n    padding: 10px 20px;\n  }\n\n  .section-template--19466783981784__custom_liquid_TMzBiR-padding {\n    padding: 0 5rem;\n    max-width: 1599px;\n    margin: auto;\n  }\n\n  nav.breadcrumb {\n    font-family: 'Poppins';\n    font-size: 12px;\n    font-weight: 400;\n    color: #00514E;\n  }\n\n  nav.breadcrumb a {\n    font-family: 'Poppins';\n    font-size: 12px;\n    font-weight: 400;\n    color: #00514E;\n    text-decoration: none;\n  }\n<\/style>","color_scheme":"","padding_top":36,"padding_bottom":52}},"main":{"type":"main-product","blocks":{"title":{"type":"title","settings":{}},"icon_with_text_P4pPcy":{"type":"icon-with-text","settings":{"layout":"vertical","icon_1":"truck","image_1":"{{ product.metafields.custom.image_1.value }}","heading_1":"{{ product.metafields.custom.item_1.value }}Rask levering","icon_2":"box","image_2":"{{ product.metafields.custom.image_2.value }}","heading_2":"{{ product.metafields.custom.item_2.value }} Lager i Norge","icon_3":"truck","heading_3":""}},"icon_with_text_HzMMXX":{"type":"icon-with-text","settings":{"layout":"horizontal","icon_1":"heart","image_1":"{{ product.metafields.custom.image_3.value }}","heading_1":"{{ product.metafields.custom.item_3.value }}","icon_2":"return","image_2":"{{ product.metafields.custom.image_4.value }}","heading_2":"{{ product.metafields.custom.item_4.value }}","icon_3":"truck","heading_3":""}},"price":{"type":"price","settings":{}},"variant_picker":{"type":"variant_picker","settings":{"picker_type":"button","swatch_shape":"none"}},"custom_liquid_xM8DxJ":{"type":"custom_liquid","disabled":true,"settings":{"custom_liquid":"<div class=\"product-stock-status\">\n  {% if product.selected_or_first_available_variant.available %}\n    <span class=\"in-stock\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0720\/9130\/4152\/files\/check-svgrepo-com_1.png?v=1748879228\"\/> På Lager <span class=\"numbers-in-stock\">({{ product.selected_or_first_available_variant.inventory_quantity }})<\/span>\n    <\/span>\n  {% else %}\n    <span class=\"out-of-stock\">\n      ❌ Ikke på lager\n    <\/span>\n<div class=\"klaviyo-form-U8LeJ8\"><\/div>\n  {% endif %}\n<\/div>\n<Style>\n.in-stock{\nfont-size: 15px;\n    font-weight: 400;\n    color: #000;\n    font-family: 'Poppins';\ndisplay:flex;\nalign-items:center;\ngap:10px;\n}\n.product-stock-status{\nbackground-color:#fff !Important;\n}\nspan.in-stock img {\n    width: 20px;\n}\n<\/style>"}},"custom_liquid_WwCPLN":{"type":"custom_liquid","name":"Add to cart previous button code","disabled":true,"settings":{"custom_liquid":"<product-form class=\"collectionAddCart custom-add-to-cart\" data-section-id=\"{{ section.id }}\">\n  {%- form 'product',\n    product,\n    id: product_form_id,\n    class: 'form add-to-cart',\n    novalidate: 'novalidate',\n    data-type: 'add-to-cart-form'\n  -%}\n    <input\n      type=\"hidden\"\n      name=\"id\"\n      value=\"{{ product.selected_or_first_available_variant.id }}\"\n      class=\"product-variant-id\"\n      {% unless product.selected_or_first_available_variant.available %}\n        disabled\n      {% endunless %}\n    >\n\n    <!-- Quantity Container -->\n    <div class=\"quantity-add-container\" style=\"display: flex; gap: 15px; align-items: center; margin-bottom: 15px;\">\n      <!-- Quantity Wrapper -->\n      {% if product.selected_or_first_available_variant.available %}\n      <div class=\"quantity-wrapper\" style=\"display: flex; align-items: center; border: 1px solid #00514E; border-radius: 10px; overflow: hidden; height: 61px; flex: 22%;\">\n        <button type=\"button\" class=\"quantity-btn minus\" style=\"background-color: #fff; border: none; width: 32px; height: 61px; font-size: 25px; cursor: pointer; border-right: 1px solid #00514E;\">−<\/button>\n        <input \n          type=\"text\" \n          name=\"quantity\" \n          value=\"1\" \n          min=\"1\" \n          class=\"product__quantity-input\" \n          style=\"width: calc(100% - 56px); text-align: center; border: none; height: 60px; font-size: 18px; font-weight: bold;\"\n        >\n        <button type=\"button\" class=\"quantity-btn plus\" style=\"background-color: #fff; border: none; width: 32px; height: 61px; font-size: 25px; cursor: pointer; border-left: 1px solid #00514E;\">+<\/button>\n      <\/div>\n      {% else %}\n      {% endif %}\n\n      <!-- Add to Cart Button -->\n      <button\n        id=\"{{ product_form_id }}-submit\"\n        type=\"submit\"\n        name=\"add\"\n        class=\"quick-add__submit button button--full-width button--secondary\"\n        aria-haspopup=\"dialog\"\n        aria-labelledby=\"{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}\"\n        aria-live=\"polite\"\n        data-sold-out-message=\"true\"\n        style=\"font-size: 20px; width: 100%; color: #fff; background-color: #00514E; line-height: 28px; border-radius: 15px; font-family: Poppins, sans-serif; font-weight: 600; cursor: pointer; border: none;\"\n        {% unless product.selected_or_first_available_variant.available %}\n          disabled\n        {% endunless %}\n      >\n        <span>\n          {%- if product.selected_or_first_available_variant.available -%}\n            {{ 'products.product.add_to_cart' | t }}\n          {%- else -%}\n            {{ 'products.product.sold_out' | t }}\n          {%- endif -%}\n        <\/span>\n        <span class=\"sold-out-message hidden\">\n          {{ 'products.product.sold_out' | t }}\n        <\/span>\n\n        {%- render 'loading-spinner' -%}\n      <\/button>\n    <\/div>\n  {%- endform -%}\n   {% render 'under-btn-text' %}\n<\/product-form>\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  \/\/ Quantity increment\/decrement functionality\n  document.querySelectorAll('.collectionAddCart').forEach(function(formContainer) {\n    const minusBtn = formContainer.querySelector('.quantity-btn.minus');\n    const plusBtn = formContainer.querySelector('.quantity-btn.plus');\n    const quantityInput = formContainer.querySelector('.product__quantity-input');\n    \n    if (minusBtn && plusBtn && quantityInput) {\n      minusBtn.addEventListener('click', function() {\n        let currentValue = parseInt(quantityInput.value);\n        if (currentValue > 1) {\n          quantityInput.value = currentValue - 1;\n        }\n      });\n      \n      plusBtn.addEventListener('click', function() {\n        let currentValue = parseInt(quantityInput.value);\n        quantityInput.value = currentValue + 1;\n      });\n      \n      \/\/ Ensure quantity is at least 1\n      quantityInput.addEventListener('change', function() {\n        if (this.value < 1) {\n          this.value = 1;\n        }\n      });\n    }\n  });\n});\n<\/script>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function () {\n\n  \/\/ Shopify variant JSON\n  const variants = {{ product.variants | json }};\n\n  \/\/ Hidden variant input inside your add to cart form\n  const variantInput = document.querySelector(\"input.product-variant-id\");\n\n  \/\/ The main product image\n  const mainImg = document.querySelector(\".product__media img, .product__main-image, .product-media img\");\n\n  \/\/ All your swatch elements\n  const swatches = document.querySelectorAll(\".variant-image-wrapper\");\n\n  if (!variantInput || swatches.length === 0) {\n    console.warn(\"Variant system not found.\");\n    return;\n  }\n\n  swatches.forEach(function (swatch) {\n    swatch.addEventListener(\"click\", function () {\n\n      const selectedVariantId = swatch.getAttribute(\"data-variant-id\");\n      const selectedVariant = variants.find(v => v.id == selectedVariantId);\n\n      if (!selectedVariant) return;\n\n      \/** 🔥 1. Update hidden variant input so Add to Cart uses correct ID *\/\n      variantInput.value = selectedVariantId;\n      variantInput.dispatchEvent(new Event(\"change\", { bubbles: true }));\n\n      \/** 🔥 2. Update selected swatch UI *\/\n      swatches.forEach(s => s.classList.remove(\"active\"));\n      swatch.classList.add(\"active\");\n\n      \/** 🔥 3. Update main product image *\/\n      if (selectedVariant.featured_image && mainImg) {\n        mainImg.src = selectedVariant.featured_image.src;\n      }\n\n      \/** 🔥 4. Update button state *\/\n      const addBtn = document.querySelector(\"#{{ product_form_id }}-submit\");\n      if (addBtn) {\n        if (selectedVariant.available) {\n          addBtn.disabled = false;\n          addBtn.querySelector(\"span\").textContent = \"Legg i handlekurv\";\n        } else {\n          addBtn.disabled = true;\n          addBtn.querySelector(\"span\").textContent = \"Utsolgt\";\n        }\n      }\n    });\n  });\n\n});\n<\/script>\n\n\n\n\n<div class=\"prdCardImgWrapper\">\n  <img style=\"margin-right: 20px\" class=\"paymentbadge\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0738\/2007\/8317\/files\/payment_logos1_58e7d9bd-9086-4798-8f32-6e79098b7ba0.png?v=1740049368\" alt=\"Kort\">\n  <img class=\"paymentbadge1\" src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0738\/2007\/8317\/files\/trust-stars.png?v=1740050015\" alt=\"Kort\">\n<\/div>\n\n<style>\n  .quantity-btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed !important;\n}\n\nform.form.add-to-cart {\n    background: #e0f8f7;\n    padding: 0 5px 2px;\n    border-bottom-left-radius: 20px;\n    border-bottom-right-radius: 20px;\n    margin: 0 !important;\n}\n.quantity-btn:hover:not(:disabled) {\n  background-color: #f5f5f5 !important;\n}\n\n.product__quantity-input:focus {\n  outline: none;\n  background-color: #f9f9f9;\n}\n\n\/* Responsive design *\/\n@media (max-width: 768px) {\n  .quantity-add-container {\n    flex-direction: column;\n    gap: 10px !important;\n  }\n  \n  .quantity-wrapper {\n    flex: 75%\n  }\n  .quantity-add-container {\n    flex-direction: row;\n}\n  .quick-add__submit {\n    width: 100% !important;\n  }\n}\n.quantity-add-container {\n  display: flex;\n  gap: 15px;\n  align-items: center;\n}\n.quantity-wrapper {\n  display: flex;\n  align-items: center;\n  border: 1px solid #00514E;\n  border-radius: 10px;\n  overflow: hidden;\n  height: 61px;\n  flex: 22%;\n}\nbutton.quantity-btn.plus,\nbutton.quantity-btn.minus {\n  background-color: #fff;\n  border: none;\n  width: 32px;\n  height: 61px;\n  font-size: 25px;\n  cursor: pointer;\n}\nbutton.quantity-btn.plus { border-left: 1px solid #00514E; }\nbutton.quantity-btn.minus { border-right: 1px solid #00514E; }\n\n.product__quantity-input {\n  width: 60px;\n  text-align: center;\n  border: none;\n  height: 60px;\n  font-size: 18px;\n  font-weight: bold;\n}\nbutton.product__add-to-cart-button {\n  font-size: 20px;\n  width: 100%;\n  color: #fff;\n  background-color: #00514E;\n  line-height: 57px;\n  border-radius: 15px;\n  font-family: Poppins, sans-serif;\n  font-weight: 600;\n  cursor: pointer;\n  flex: 100%;\n  border: none;\n  transition: opacity 0.3s ease;\n}\nbutton.product__add-to-cart-button:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n}\n.prdCardImgWrapper {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  margin-top: 15px;\n}\n.prdCardImgWrapper .paymentbadge { width: 24%; }\n.prdCardImgWrapper .paymentbadge1 { width: 42%; }\n<\/style>\n\n<script>\n\n  \/\/ 2. Add to cart function (SIMPLE VERSION)\nasync function addToCart() {\n  console.log('🛒 Add to cart clicked!');\n\n  const addToCartBtn = document.getElementById(\"add-to-cart-btn\");\n  console.log('🔍 Found button:', addToCartBtn);\n\n  const variantInput = document.querySelector('input[name=\"id\"]');\n  const qtyInput = document.querySelector('input[name=\"quantity\"]');\n  console.log('🔍 Variant input:', variantInput, 'Qty input:', qtyInput);\n\n  if (!variantInput || !qtyInput) {\n    console.error('❌ Missing variant ID or quantity input');\n    return;\n  }\n\n  const variantId = variantInput.value;\n  const quantity = parseInt(qtyInput.value) || 1;\n\n  console.log('🛒 Adding to cart - Variant:', variantId, 'Quantity:', quantity);\n\n  const originalText = addToCartBtn.textContent;\n  addToCartBtn.disabled = true;\n  addToCartBtn.textContent = 'Legger til...';\n  addToCartBtn.style.opacity = '0.7';\n\n  try {\n    console.log('🌐 Sending fetch request to \/cart\/add.js ...');\n    const response = await fetch('\/cart\/add.js', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application\/json' },\n      body: JSON.stringify({ id: variantId, quantity })\n    });\n\n    console.log('🛒 Response object:', response);\n\n    if (!response || !response.ok) {\n      console.error('❌ Response invalid or not OK:', response);\n      const errorText = response ? await response.text() : 'No response received';\n      throw new Error(errorText);\n    }\n\n    const result = await response.json();\n    console.log('✅ Product added successfully:', result);\n\n    if (typeof updateCartCount === 'function') {\n      console.log('🔄 Calling global updateCartCount()');\n      updateCartCount();\n    } else {\n      console.warn('⚠️ Global updateCartCount() not found!');\n    }\n\n    showSuccessMessage();\n\n  } catch (error) {\n    console.error('❌ Add to cart error:', error);\n    {% comment %} alert(error.message || 'Feil ved å legge produktet til i handlekurven'); {% endcomment %}\n  } finally {\n    addToCartBtn.disabled = false;\n    addToCartBtn.textContent = originalText;\n    addToCartBtn.style.opacity = '1';\n  }\n}\n\n\n  \/\/ 3. Update cart count\n  async function updateCartCountPrdDetailPage() {\n    try {\n      const response = await fetch('\/cart.js');\n      const cart = await response.json();\n      \n      console.log('🛒 Cart updated, item count:', cart.item_count);\n      \n      \/\/ Update cart bubbles\n      const bubbles = document.querySelectorAll('.cart-count-bubble');\n      bubbles.forEach(bubble => {\n        const visible = bubble.querySelector('span[aria-hidden=\"true\"]');\n        const hidden = bubble.querySelector('.visually-hidden');\n        \n        if (visible) visible.textContent = cart.item_count;\n        if (hidden) hidden.textContent = `${cart.item_count} items`;\n        \n        if (cart.item_count > 0) {\n          bubble.classList.remove('hidden');\n        } else {\n          bubble.classList.add('hidden');\n        }\n      });\n      \n    } catch (error) {\n      console.error('⚠️ Error updating cart count:', error);\n    }\n  }\n\n  \/\/ 4. Show success message\n  function showSuccessMessage() {\n    \/\/ Remove existing messages\n    document.querySelectorAll('.cart-success-toast').forEach(el => el.remove());\n    \n    const toast = document.createElement('div');\n    toast.className = 'cart-success-toast';\n    toast.textContent = 'Lagt i handlekurven ✅';\n    toast.style.cssText = `\n      position: fixed;\n      bottom: 20px;\n      left: 50%;\n      transform: translateX(-50%);\n      padding: 12px 24px;\n      border-radius: 10px;\n      background: #00514e;\n      color: #fff;\n      font-family: Poppins, sans-serif;\n      font-weight: 600;\n      z-index: 9999;\n      box-shadow: 0 6px 20px rgba(0,0,0,.15);\n      animation: toastSlideUp 0.3s ease-out;\n    `;\n\n    \/\/ Add animation styles\n    if (!document.querySelector('#toast-animations')) {\n      const style = document.createElement('style');\n      style.id = 'toast-animations';\n      style.textContent = `\n        @keyframes toastSlideUp {\n          from { transform: translateX(-50%) translateY(100px); opacity: 0; }\n          to { transform: translateX(-50%) translateY(0); opacity: 1; }\n        }\n        @keyframes toastSlideDown {\n          from { transform: translateX(-50%) translateY(0); opacity: 1; }\n          to { transform: translateX(-50%) translateY(100px); opacity: 0; }\n        }\n      `;\n      document.head.appendChild(style);\n    }\n    \n    document.body.appendChild(toast);\n    \n    \/\/ Remove after 2 seconds\n    setTimeout(() => {\n      toast.style.animation = 'toastSlideDown 0.3s ease-in';\n      setTimeout(() => toast.remove(), 300);\n    }, 2000);\n  }\n\n  \/\/ 5. Out of stock check\n  function checkOutOfStock() {\n    const outOfStockElements = document.querySelectorAll('.out-of-stock, .sold-out');\n    console.log('Out of stock elements found:', outOfStockElements.length);\n    \n    if (outOfStockElements.length > 0) {\n      addToCartBtn.disabled = true;\n      addToCartBtn.textContent = 'Utsolgt';\n      addToCartBtn.style.cursor = 'not-allowed';\n      addToCartBtn.style.opacity = '0.5';\n      \n      \/\/ Disable quantity controls\n      document.querySelectorAll('.quantity-btn, .product__quantity-input').forEach(el => {\n        el.disabled = true;\n        el.style.opacity = '0.6';\n        el.style.cursor = 'not-allowed';\n      });\n    }\n  }\n\n  \/\/ ===== INITIALIZE EVERYTHING =====\n  \n  \/\/ Initialize quantity buttons\n  initQuantityButtons();\n  \n  \/\/ Check out of stock status\n  checkOutOfStock();\n  \n  \/\/ Add click event to button (DIRECT APPROACH)\n  addToCartBtn.addEventListener('click', function(e) {\n    e.preventDefault();\n    e.stopPropagation();\n    e.stopImmediatePropagation();\n    \n    console.log('🛒 Button click captured!');\n    addToCart();\n  });\n\n  \/\/ Also prevent form submission if it exists\n  if (form) {\n    form.addEventListener('submit', function(e) {\n      e.preventDefault();\n      e.stopPropagation();\n      console.log('🛒 Form submission prevented, using button click instead');\n      return false;\n    });\n  }\n\n  console.log('=== ✅ PRODUCT FORM FULLY INITIALIZED ===');\n});\n\n\/\/ Make sure this runs even if DOMContentLoaded already fired\nif (document.readyState === 'loading') {\n  document.addEventListener('DOMContentLoaded', init);\n} else {\n  \/\/ DOM already loaded, initialize immediately\n  setTimeout(() => {\n    {% comment %} const addToCartBtn = document.getElementById('AddToCart-{{ product.id }}'); {% endcomment %}\n     const addToCartBtn = document.getElementById('add-to-cart-btn');\n    if (addToCartBtn) {\n      console.log('🛒 Late initialization');\n      addToCartBtn.addEventListener('click', function(e) {\n        e.preventDefault();\n        alert('Add to cart would work here!');\n      });\n    }\n  }, 100);\n}\n<\/script>"}},"custom_liquid_FqWzCt":{"type":"custom_liquid","settings":{"custom_liquid":"{% render 'add-to-cart-btn' %}"}},"custom_liquid_rrzLC8":{"type":"custom_liquid","name":"Show Dynamic message","disabled":true,"settings":{"custom_liquid":"<p id=\"reward-message-prdDetail\" style=\"text-align:center; font-weight: bold; color: #fff; margin-top: 10px;margin-bottom:0px;\"><\/p>\n<script>\n  function updateProgressBarFromCart() {\n    fetch('\/cart.js')\n      .then(res => res.json())\n      .then(cart => {\n        const totalQty = cart.items.reduce((sum, item) => sum + item.quantity, 0);\n\n        \/\/ Calculate percentage fill and color\n        let percent = 0;\n        let fillColor = '#00514e'; \/\/ default\n\n        if (totalQty >= 2) {\n          percent = 25;\n          fillColor = 'rgb(255, 221, 72)';\n        }\n        if (totalQty >= 3) {\n          percent = 50;\n          fillColor = 'rgb(255, 221, 72)';\n        }\n        if (totalQty >= 4) {\n          percent = 75;\n          fillColor = 'rgb(255, 221, 72)';\n        }\n        if (totalQty >= 5) {\n          percent = 100;\n          fillColor = 'rgb(255, 221, 72)';\n\n        }\n\n \n       const fillEl = document.getElementById('progressFill');\n        const bgEl = document.querySelector('.progress-bar-background');\n        if (fillEl) {\n          fillEl.style.width = percent + '%';\n          fillEl.style.backgroundColor = fillColor;\n        }\n\n        \/\/ Change background color when full\n        if (bgEl) bgEl.style.backgroundColor = (percent === 100) ? '#ddd' : '#ddd';\n        \/\/ Update reward message\n        const msgEl = document.getElementById('reward-message');\n        const rewards = [\n          { qty: 2, reward: 'gratis frakt' },\n          { qty: 3, reward: '20 % rabatt' },\n          { qty: 4, reward: '25 % rabatt' },\n          { qty: 5, reward: '30 % rabatt' }\n        ];\n\n        if (msgEl) {\n          const next = rewards.find(r => totalQty < r.qty);\n          if (totalQty >= 5) {\n            msgEl.textContent = '🎉 Du har låst opp den beste belønningen!';\n          } else if (next) {\n            const remaining = next.qty - totalQty;\n            msgEl.textContent = `Legg til ${remaining} produkt ${remaining > 1 ? 's' : ''} til for å få ${next.reward}`;\n          } else {\n            msgEl.textContent = '';\n          }\n        }\n      });\n  }\n\n  \/\/ Initial update\n  document.addEventListener('DOMContentLoaded', updateProgressBarFromCart);\n  \n  \/\/ Listen for Shopify section reloads\n  document.addEventListener('shopify:section:load', updateProgressBarFromCart);\n  \n  \/\/ Custom event listener for AJAX cart updates\n  document.addEventListener('ajaxCart.afterCartUpdate', updateProgressBarFromCart);\n  \n  \/\/ Fallback polling every 2 seconds\n  setInterval(updateProgressBarFromCart, 2000);\n<\/script>"}},"quantity_selector":{"type":"quantity_selector","disabled":true,"settings":{}},"buy_buttons":{"type":"buy_buttons","disabled":true,"settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"custom_liquid_TJXkN7":{"type":"custom_liquid","disabled":true,"settings":{"custom_liquid":"<div class=\"custom-accordion-wrapper\">\n  <button class=\"custom-accordion-toggle\" aria-expanded=\"false\">\n    <span class=\"custom-accordion-label\">Beskrivelse<\/span>\n    <span class=\"custom-toggle-text\">Les mer<\/span>\n  <\/button>\n  <div class=\"custom-accordion-content\">\n    <p>{{ product.description }}<\/p>\n  <\/div>\n<\/div>\n\n<style>\n.custom-accordion-wrapper {\n  border-radius: 6px;\n  margin-bottom: 20px;\n  overflow: hidden;\n}\n\n.custom-accordion-toggle {\n  width: 100%;\n  text-align: left;\n  padding: 15px;\n  font-weight: 400;\n  font-size: 20px;\n  cursor: pointer;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  background-color: #fff;\n  color: #00514E;\n  border: 1px solid #00514E;\n  transition: background-color 0.3s, color 0.3s;\n    border-radius: 10px;\n    \/\/border-top-left-radius: 10px;\n}\n\n.custom-accordion-toggle:hover {\n  background-color: #00514E;\n  color: #fff;\n}\n\n.custom-accordion-toggle:hover .custom-accordion-icon path {\n  stroke: #fff;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] {\n  background-color: #00514E;\n  color: #fff;\n  border-color: #00514E;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] .custom-accordion-icon path {\n  stroke: #fff;\n}\n\n.custom-accordion-icon {\n  transition: transform 0.3s ease;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] .custom-accordion-icon {\n  transform: rotate(45deg);\n}\n\n.custom-accordion-content {\n  display: none;\n  padding: 15px;\n  background-color: #fff;\n  border:1px solid #00541e;\nborder-bottom-left-radius: 10px;\n    border-bottom-right-radius: 10px;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] + .custom-accordion-content {\n  display: block;\n}\nspan.custom-accordion-label {\n    font-size: 18px;\n    font-weight: 400;\n    font-family: Poppins, sans-serif;\n}\n.custom-toggle-text{\nfont-size:14px;}\n<\/style>\n\n<script>\n  document.querySelectorAll('.custom-accordion-toggle').forEach(button => {\n    button.addEventListener('click', () => {\n      const isExpanded = button.getAttribute('aria-expanded') === 'true';\n\n      \/\/ Close all accordions first\n      document.querySelectorAll('.custom-accordion-toggle').forEach(btn => {\n        btn.setAttribute('aria-expanded', 'false');\n        btn.querySelector('.custom-toggle-text').textContent = 'Les mer';\n      });\n\n      if (!isExpanded) {\n        button.setAttribute('aria-expanded', 'true');\n        button.querySelector('.custom-toggle-text').textContent = 'Les mindre';\n      }\n    });\n  });\n<\/script>"}},"description":{"type":"description","disabled":true,"settings":{}},"share":{"type":"share","disabled":true,"settings":{"share_label":"Share"}},"custom_liquid_LMh4qq":{"type":"custom_liquid","settings":{"custom_liquid":"<div class=\"newPrdCustomWrap\"><div id=\"6914cef78a75bb8026350a7b\