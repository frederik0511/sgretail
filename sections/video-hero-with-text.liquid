<div class="video-hero-wrapper">
  <video autoplay muted loop playsinline class="video-bg">
    <source src="{{ section.settings.video_url | escape }}" type="video/mp4">
    Your browser does not support the video tag.
  </video>

  <div class="video-overlay">
    <div class="content-box">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>
      <a href="{{ section.settings.button_link }}" class="hero-button">
        {{ section.settings.button_text }}
      </a>
    </div>
  </div>
</div>

<style>
.video-hero-wrapper {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 80vh;
}

.video-bg {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: translate(-50%, -50%);
  z-index: 1;
}

.video-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  justify-content: flex-end;
  align-items: flex-end; /* 👈 Flytter boksen ned */
  padding: 20px;
  padding-bottom: 40px; /* 👈 Justér denne for å styre avstanden fra bunnen */
  z-index: 2;
  text-align: center;
}

.content-box {
  color: #fff;
  background: rgba(255, 255, 255, 0.9);
  padding: 30px 40px;
  border-radius: 8px;
  max-width: 500px;
}

.content-box h2 {
  font-size: 28px;
  margin-bottom: 10px;
  color: #111;
}

.content-box p {
  font-size: 16px;
  color: #333;
  margin-bottom: 20px;
}

.hero-button {
  padding: 10px 20px;
  background-color: #111;
  color: #fff;
  text-decoration: none;
  border-radius: 5px;
  font-weight: bold;
}
@media screen and (max-width: 768px) {
    .video-hero-wrapper {;
  height: 26vh;
}

.video-bg {

  width: 100%;
  height: auto%;
}

.video-overlay {
  height: 26vh;
}

  }
</style>

{% schema %}
{
  "name": "Video With Text",
  "tag": "section",
  "class": "video-hero-section-with-text",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "MP4 Video URL (Upload via Files)",
      "default": "https://cdn.shopify.com/s/files/1/0000/0000/files/sample-video.mp4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made Just for You"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Create a T-shirt that reflects your style, your message, and your personality."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Video With Text"
    }
  ]
}
{% endschema %}











