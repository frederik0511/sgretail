{% comment %} {{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-related-products.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- style -%}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}
.swiper-button-next, swiper-button-prev{display:block;}
button.quick-add__submit.button.button--full-width.button--secondary {
    width: 100%;
    color: #fff;
    line-height: 28px;
    font-weight: 600;
    cursor: pointer;
    padding-left: 0;
    padding-right: 0;
    border-radius: 10px;
    font-family: Poppins;
    font-size: 16px;
}
/* small helpful overrides */
.related-products-slider-{{ section.id }} .swiper-slide { display: flex; flex-direction: column; }
.related-products-slider-{{ section.id }} .product-card { padding: 12px; border-radius: 10px; background: #fff; display:flex; flex-direction:column; height:100%; box-sizing:border-box; }
.related-products-slider-{{ section.id }} .product-card .prdCardImgWrapper { text-align:center; margin-bottom:10px; }
.related-products-slider-{{ section.id }} .product-card .product-meta { flex:1; display:flex; flex-direction:column; justify-content:space-between; }
.related-products-slider-{{ section.id }} .quantity-wrapper { display:flex; align-items:center; gap:8px; }
.related-products-slider-{{ section.id }} .product__quantity-input { width:60px; text-align:center; }
.related-products-slider-{{ section.id }} .quick-add__submit { margin-top:8px; }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient greyBgColor section-{{ section.id }}-padding">
  <div class="page-width isolate">
    {% if section.settings.heading != blank %}
      <h2 class="related-products__heading inline-richtext {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% assign collection = collections[section.settings.collection] %}
    {% if collection and collection.products.size > 0 %}
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" />
      <div class="swiper related-products-slider-{{ section.id }}">
        <div class="swiper-wrapper">
          {% for product in collection.products limit: section.settings.products_to_show %}
            <div class="swiper-slide">
              <div class="product-card" data-product-id="{{ product.id }}">
                <div class="prdCardImgWrapper">
                  <a href="{{ product.url }}">
                    <img src="{{ product.featured_image | img_url: '400x' }}" alt="{{ product.title | escape }}" loading="lazy" width="300" height="300" />
                  </a>
                </div>

                <div class="product-meta">
                  <div>
                    <h3 class="related-product-title">{{ product.title }}</h3>

                    {%- if product.compare_at_price > product.price -%}
                      <p class="product-price">
                        <span class="regular-price" style="text-decoration: line-through; color: #999;">
                          {{ product.compare_at_price | money }}
                        </span>
                        <span class="sale-price" style="color: #00514E; font-weight: bold;">
                          {{ product.price | money }}
                        </span>
                      </p>
                    {%- else -%}
                      <p class="product-price">
                        <span class="sale-price">{{ product.price | money }}</span>
                      </p>
                    {%- endif -%}
                  </div>

                  <!-- Inline product form (unique ids) -->
                  <product-form class="collectionAddCart custom-add-to-cart" data-section-id="{{ section.id }}">
                    {%- assign form_id = 'related_product_' | append: section.id | append: '_' | append: product.id -%}
                    {%- form 'product', product, id: form_id, class: 'form add-to-cart', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" class="product-variant-id" />

                      <div class="quantity-add-container custom-related-product" style="display:flex;gap:10px;align-items:center;">
                        <div class="quantity-wrapper custom-related" style="border:1px solid #e6e6e6;border-radius:8px;padding:4px;">
                          <button type="button" class="quantity-btn minus" data-target="{{ form_id }}" aria-label="Decrease">−</button>
                          <input type="text" name="quantity" value="1" min="1" class="product__quantity-input" data-target="{{ form_id }}" />
                          <button type="button" class="quantity-btn plus" data-target="{{ form_id }}" aria-label="Increase">+</button>
                        </div>

                        <button
                          id="{{ form_id }}-submit"
                          type="submit"
                          name="add"
                          class="quick-add__submit button button--full-width button--secondary"
                          data-target="{{ form_id }}"
                          {% unless product.selected_or_first_available_variant.available %} disabled {% endunless %}
                        >
                          {%- if product.selected_or_first_available_variant.available -%} Legg i handlekurv {%- else -%} Utsolgt {%- endif -%}
                        </button>
                      </div>
                    {%- endform -%}
                  </product-form>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="swiper-button-next swiper-next-{{ section.id }}"></div>
        <div class="swiper-button-prev swiper-prev-{{ section.id }}"></div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>

      <script>
        (function(){
          // Wait for DOM ready
          function onReady(fn){ if (document.readyState!='loading') fn(); else document.addEventListener('DOMContentLoaded',fn); }

          onReady(function(){
            var selector = '.related-products-slider-{{ section.id }}';
            var sliderEl = document.querySelector(selector);
            if (!sliderEl) return;

            // Initialize Swiper - unique navigation elements
            new Swiper(selector, {
              loop: true,
              spaceBetween: 20,
              slidesPerView: 1.15,
              navigation: {
                nextEl: '.swiper-next-{{ section.id }}',
                prevEl: '.swiper-prev-{{ section.id }}'
              },
              breakpoints: {
                640: { slidesPerView: 2, spaceBetween: 16 },
                768: { slidesPerView: 3, spaceBetween: 20 },
                1024: { slidesPerView: {{ section.settings.columns_desktop | default: 4 }}, spaceBetween: 24 }
              }
            });

            // Quantity buttons & Add-to-cart logic (per form)
            document.querySelectorAll('.product-card').forEach(function(card){
              var form = card.querySelector('form.add-to-cart');
              if (!form) return;

              var qtyInput = form.querySelector('input[name="quantity"]');
              var plus = form.querySelector('.quantity-btn.plus');
              var minus = form.querySelector('.quantity-btn.minus');
              var submitBtn = form.querySelector('button[type="submit"]');

              // sanitize initial
              if (qtyInput) { qtyInput.value = qtyInput.value || '1'; }

              if (plus) plus.addEventListener('click', function(e){
                e.preventDefault();
                var v = parseInt(qtyInput.value || '1',10); qtyInput.value = v + 1;
              });
              if (minus) minus.addEventListener('click', function(e){
                e.preventDefault();
                var v = parseInt(qtyInput.value || '1',10);
                if (v > 1) qtyInput.value = v - 1;
              });

              // AJAX submit
              form.addEventListener('submit', function(e){
                e.preventDefault();
                e.stopImmediatePropagation();

                var variantInput = form.querySelector('input[name="id"]');
                var quantity = parseInt(qtyInput.value || '1', 10);
                var variantId = variantInput ? variantInput.value : null;
                if (!variantId) { alert('Produktvariant ikke funnet'); return; }

                // disable UI
                submitBtn.disabled = true;
                var originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = 'Legger til...';

                fetch('/cart/add.js', {
                  method: 'POST',
                  headers: {'Content-Type':'application/json'},
                  body: JSON.stringify({ id: variantId, quantity: quantity })
                }).then(function(res){
                  if (!res.ok) return res.json().then(function(err){ throw err; });
                  return res.json();
                }).then(function(data){
                  // success toast
                  var toast = document.createElement('div');
                  toast.textContent = 'Lagt i handlekurven ✅';
                  toast.style.cssText = 'position:fixed;bottom:20px;left:50%;transform:translateX(-50%);padding:10px 14px;border-radius:8px;background:#00514e;color:#fff;z-index:99999;';
                  document.body.appendChild(toast);
                  setTimeout(function(){ toast.remove(); }, 1800);

                  // update cart bubble(s)
                  fetch('/cart.js').then(r=>r.json()).then(function(cart){
                    document.querySelectorAll('.cart-count-bubble').forEach(function(b){
                      var visible = b.querySelector('span[aria-hidden="true"]');
                      var hidden = b.querySelector('.visually-hidden');
                      if (visible) visible.textContent = cart.item_count;
                      if (hidden) hidden.textContent = cart.item_count + ' items';
                      if (cart.item_count > 0) b.classList.remove('hidden'); else b.classList.add('hidden');
                    });
                  });
                }).catch(function(err){
                  var msg = (err && (err.description || err.message)) || 'Feil ved legging i handlekurv';
                  alert(msg);
                  console.error(err);
                }).finally(function(){
                  submitBtn.disabled = false;
                  submitBtn.innerHTML = originalText;
                });
              });
            }); // end forEach product-card
          }); // end onReady
        })();
      </script>

    {% else %}
      <p>No products found in the selected collection.</p>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Related Products Slider",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "collection", "id": "collection", "label": "Select collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 8, "label": "Number of products to show" },
    { "type": "range", "id": "columns_desktop", "min": 1, "max": 6, "step": 1, "default": 4, "label": "Desktop columns (used as slidesPerView at large screens)" },
    { "type": "select", "id": "heading_size", "label": "Heading size", "options":[ { "value":"h2","label":"Medium" },{ "value":"h1","label":"Large" } ], "default":"h2" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default":"background-1" },
    { "type": "select", "id": "image_shape", "label":"Image shape", "options":[ { "value":"default","label":"Default" }, { "value":"blob","label":"Blob" } ], "default":"default" },
    { "type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Top padding","default":36 },
    { "type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Bottom padding","default":36 }
  ],
  "presets": [ { "name": "Related Products Slider", "category": "Products" } ]
}
{% endschema %} {% endcomment %}



