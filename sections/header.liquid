<script>
(function () {
  const boxes = document.querySelectorAll('.cart-savings-box');
  if (!boxes.length) return;

  let lastSavings = null;
  let running = false;

  function formatMoney(cents) {
    return (cents / 100).toFixed(2).replace('.', ',') + ' kr';
  }

  function calculateSavings(cart) {
    let total = 0;

    cart.items.forEach(item => {
      const discount =
        (item.original_line_price || item.final_line_price) -
        item.final_line_price;

      if (discount > 0) total += discount;
    });

    return total;
  }

  function updateCartSavings() {
    if (running) return;
    running = true;

    fetch('/cart.js')
      .then(r => r.json())
      .then(cart => {
        const savings = calculateSavings(cart);

        if (savings !== lastSavings) {
          boxes.forEach(box => {
            const amountEl = box.querySelector('.cart-savings-amount');

            if (!amountEl) return;

            if (savings > 0) {
              box.style.display = 'flex';
              amountEl.textContent = formatMoney(savings);
            } else {
              box.style.display = 'block';
              amountEl.textContent = formatMoney(0);
            }
          });

          lastSavings = savings;
        }
      })
      .finally(() => running = false);
  }

  // Initial load
  updateCartSavings();

  // Listen to cart updates
  document.addEventListener('cart:change', updateCartSavings);
  document.addEventListener('cart:refresh', updateCartSavings);
})();
</script>


<script>
(function () {
  const originalFetch = window.fetch;

  window.fetch = function (...args) {
    return originalFetch.apply(this, args).then(response => {
      try {
        const url = args[0]?.toString() || '';

        if (
          url.includes('/cart/add') ||
          url.includes('/cart/change') ||
          url.includes('/cart/update')
        ) {
          document.dispatchEvent(new Event('cart:change'));
        }
      } catch (e) {}

      return response;
    });
  };
})();
</script>



