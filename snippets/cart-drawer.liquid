<script>
// ✅ First: formatMoney helper
function formatMoney(cents, format = "{{amount_no_decimals}} kr") {
  if (typeof cents === 'string') {
    cents = cents.replace('.', '');
  }

  function formatWithDelimiters(number, precision = 2, thousands = '.', decimal = ',') {
    number = (number / 100.0).toFixed(precision);
    const parts = number.split('.');
    const dollars = parts[0].replace(/(\d)(?=(\d{3})+(?!\d))/g, `$1${thousands}`);
    const cents = parts[1] ? decimal + parts[1] : '';
    return dollars + cents;
  }

  return format.replace('{{amount}}', formatWithDelimiters(cents, 2))
               .replace('{{amount_no_decimals}}', formatWithDelimiters(cents, 0))
               .replace('{{amount_with_comma_separator}}', formatWithDelimiters(cents, 2, '.', ','))
               .replace('{{amount_no_decimals_with_comma_separator}}', formatWithDelimiters(cents, 0, '.', ','));
}

// ✅ Second: updateCartDrawer function
function updateCartDrawer(cart) {
  const cartDrawer = document.querySelector('cart-drawer');
  const cartItemsContainer = document.getElementById('CartDrawer-CartItems');
  const totalsContainer = document.querySelector('.totals__total-value');
  const cartCountBubble = document.querySelector('.cart-count-bubble span');

  if (!cartDrawer || !cartItemsContainer) {
    console.warn('Cart drawer or items container not found');
    return;
  }

  // Open the drawer
  cartDrawer.classList.add('active');
  // cartDrawer.style.visibility = 'visible';

  if (cart.item_count === 0) {
    cartItemsContainer.innerHTML = `
      <div class="drawer__inner-empty">
        <div class="cart-drawer__warnings center">
          <div class="cart-drawer__empty-content">
            <h2 class="cart__empty-text">Your cart is empty</h2>
            <a href="/collections/all" class="button">Continue shopping</a>
          </div>
        </div>
      </div>
    `;
  } else {
    let itemsHTML = `
      <div class="drawer__cart-items-wrapper">
        <table class="cart-items" role="table">
          <tbody role="rowgroup">
    `;

    cart.items.forEach((item, index) => {
      itemsHTML += `
        <tr id="CartDrawer-Item-${index + 1}" class="cart-item" role="row">
          <td class="cart-item__media" role="cell">
            ${item.image ? `<img src="${item.image}" alt="${item.title}" width="100">` : ''}
          </td>
          <td class="cart-item__details" role="cell">
            <a href="${item.url}" class="cart-item__name h4 break">${item.product_title}</a>
            <div class="product-option">
              ${formatMoney(item.price)}
            </div>
          </td>
          <td class="cart-item__totals right test" role="cell">
            <div class="cart-item__price-wrapper">
              <span class="price price--end nabeel">${formatMoney(item.line_price)}</span>
            </div>
          </td>
          <td class="cart-item__quantity" role="cell">
            <div class="cart-item__quantity-wrapper">
              <quantity-input class="quantity cart-quantity">
                <button class="quantity__button" name="minus" type="button">
                  <span class="svg-wrapper">−</span>
                </button>
                <input class="quantity__input" type="number" value="${item.quantity}" min="0" aria-label="Quantity">
                <button class="quantity__button" name="plus" type="button">
                  <span class="svg-wrapper">+</span>
                </button>
              </quantity-input>
            </div>
          </td>
        </tr>
      `;
    });

    itemsHTML += `
          </tbody>
        </table>
      </div>
    `;

    cartItemsContainer.innerHTML = itemsHTML;
  }

  // Update totals
  if (totalsContainer) {
    totalsContainer.textContent = formatMoney(cart.total_price);
  }

  // Update item count
  if (cartCountBubble) {
    cartCountBubble.textContent = cart.item_count;
  }
}

// ✅ Third: refreshCart function
function refreshCart() {
  fetch(window.location.pathname + '?sections=cart-drawer')
    .then((res) => res.json())
    .then((data) => {
      const parser = new DOMParser();
      const html = parser.parseFromString(data['cart-drawer'], 'text/html');

      const newDrawer = html.querySelector('#CartDrawer');
      const currentDrawer = document.querySelector('#CartDrawer');

      if (newDrawer && currentDrawer) {
        currentDrawer.innerHTML = newDrawer.innerHTML;
      }

      // Open the drawer
      const cartDrawerEl = document.querySelector('cart-drawer');
      if (cartDrawerEl) {
        cartDrawerEl.classList.add('active');
        // cartDrawerEl.style.visibility = 'visible';

        // ✅ Fix 'is-empty' class
        const itemCount = html.querySelectorAll('tr.cart-item').length;
        if (itemCount > 0) {
          cartDrawerEl.classList.remove('is-empty');
        } else {
          cartDrawerEl.classList.add('is-empty');
        }
      }

      // ✅ Update cart count bubble if exists
      fetch('/cart.js')
        .then(res => res.json())
        .then(cart => {
          const countBubble = document.querySelector('.cart-count-bubble span');
          if (countBubble) {
            countBubble.textContent = cart.item_count;
          }
        });
    })
    .catch((err) => {
      console.error('❌ Error refreshing cart drawer:', err);
    });
}


// ✅ Make refreshCart globally available
window.refreshCart = refreshCart;
  window.updateCartDrawer = updateCartDrawer;
</script>

