    <button class="close-btn" style="position:absolute;top:10px;right:10px;background: transparent;
    border: 0px;">×</button>

    <div id="modalInnerContent"></div>
  </div>
</div>

    <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical page-width{% endif %}">
