{% comment %} new code {% endcomment %}
{% if product.compare_at_price > product.price %}

  {% assign original = product.compare_at_price | divided_by: 100.0 %}
  {% assign sale = product.price | divided_by: 100.0 %}
  {% assign discount_percent = sale | minus: original | divided_by: original | times: -100 %}
  {% assign discount_percent_decimal = discount_percent | round: 2 %}

  <p class="product-price" style="position: relative;">

    <!-- Original Compare-at price -->
    <span style="text-decoration: line-through; color: #5FB3C4;">
      {{
        product.compare_at_price
        | money_without_currency
        | replace: '.', ','
      }} NOK
    </span>

    <!-- Sale price -->
    <span style="color:#00514E; font-weight:bold; margin-left:6px;">
      {{
        product.price
        | money_without_currency
        | replace: '.', ','
      }} NOK
    </span>

    <!-- Discount percentage badge -->
    <span style="
      font-weight:bold;
      margin-left:8px;
      color: #fff;
      position: absolute;
      right: 0;
      background-color: #00514E;
      padding: 5px 10px;
      border-radius: 10px;
      bottom: 230px;
    ">
      {{ discount_percent_decimal | replace: '.', ',' }}%
    </span>

  </p>

{% else %}

  <p class="product-price">
    {{
      product.price
      | money_without_currency
      | replace: '.', ','
    }} NOK
  </p>

{% endif %}


                  </div>

                  {%- assign product_form_id = 'related_product_' | append: section.id | append: '_' | append: product.id -%}
                  <product-form class="collectionAddCart custom-add-to-cart" data-section-id="{{ section.id }}">
                    {%- form 'product',
                      product,
                      id: product_form_id,
                      class: 'form add-to-cart',
                      novalidate: 'novalidate',
                      data-type: 'add-to-cart-form'
                    -%}
                      <input
                        type="hidden"
                        name="id"
                        value="{{ product.selected_or_first_available_variant.id }}"
                        class="product-variant-id"
                        {% unless product.selected_or_first_available_variant.available %} disabled {% endunless %}
                      >

                      <div class="quantity-add-container custom-related-product" style="display:flex;gap:15px;align-items:center;margin-bottom:15px;">
                        <div class="quantity-wrapper custom-related">
                          <button type="button" onclick="decreaseQty(this)" class="quantity-btn minus" style="background-color:#fff;border:none;width:32px;height:50px;font-size:25px;cursor:pointer;border-right:1px solid #00514E;">−</button>
                          <input 
                            type="text" 
                            name="quantity" 
                            value="1" 
                            min="1" 
                            class="product__quantity-input" 
                            style="width:calc(100% - 56px);text-align:center;border:none;height:50px;font-size:18px;font-weight:bold;"
                          >
                          <button type="button" onclick="increaseQty(this)" class="quantity-btn plus" style="background-color:#fff;border:none;width:32px;height:50px;font-size:25px;cursor:pointer;border-left:1px solid #00514E;">+</button>
                        </div>

                        <button
                          id="{{ product_form_id }}-submit"
                          type="submit"
                          name="add"
                          class="quick-add__submit button button--full-width button--secondary"
                          aria-haspopup="dialog"
                          aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
                          aria-live="polite"
                          data-sold-out-message="true"
                          {% unless product.selected_or_first_available_variant.available %} disabled {% endunless %}
                        >
                          <span>
                            {% if product.selected_or_first_available_variant.available %}
                              Legg i handlekurv
                            {% else %}
                              Utsolgt
                            {% endif %}
                          </span>
                          <span class="sold-out-message hidden">Utsolgt</span>
                          {% render 'loading-spinner' %}
                        </button>
                      </div>
                    {%- endform -%}
                  </product-form>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="swiper-button-next swiper-next-{{ section.id }} related-product-slider"></div>
        <div class="swiper-button-prev swiper-prev-{{ section.id }} related-product-slider"></div>
      </div>

      <!-- ✅ Working Swiper Initialization -->
      <script>
      (function() {
        function loadSwiper() {
          return new Promise(function(resolve, reject) {
            if (window.Swiper) return resolve();
            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js';
            script.onload = resolve;
            script.onerror = reject;
            document.head.appendChild(script);

            // ensure CSS
            if (![...document.styleSheets].some(s => s.href && s.href.includes('swiper-bundle.min.css'))) {
              const css = document.createElement('link');
              css.rel = 'stylesheet';
              css.href = 'https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css';
              document.head.appendChild(css);
            }
          });
        }

        function initRelatedSlider() {
          const selector = ".related-products-slider-{{ section.id }}";
          const el = document.querySelector(selector);
          if (!el) return;

          // Destroy if exists
          if (el._swiperInstance && typeof el._swiperInstance.destroy === "function") {
            el._swiperInstance.destroy(true, true);
          }

          el._swiperInstance = new Swiper(el, {
            loop: true,
            spaceBetween: 20,
            slidesPerView: 1.15,
            navigation: {
              nextEl: ".swiper-next-{{ section.id }}",
              prevEl: ".swiper-prev-{{ section.id }}"
            },
            breakpoints: {
              640: { slidesPerView: 2 },
              768: { slidesPerView: 3 },
              1024: { slidesPerView: {{ section.settings.columns_desktop | default: 4 }} }
            }
          });

          console.log("✅ Related Products Slider initialized for section {{ section.id }}");
        }

        // Run on load
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", () => loadSwiper().then(initRelatedSlider));
        } else {
          loadSwiper().then(initRelatedSlider);
        }

        // Reinit in Theme Editor
        document.addEventListener('shopify:section:load', (e) => {
          if (e.target && e.target.querySelector(".related-products-slider-{{ section.id }}")) {
            loadSwiper().then(initRelatedSlider);
          }
        });
      })();
      </script>

    {% else %}
      <p>Ingen produkter fundet i den valgte kollektion.</p>
    {% endif %}
  </div>
</div>

