                variantInput.dispatchEvent(new Event('change', { bubbles: true }));
              }

              document.querySelectorAll('.variant-image-wrapper')
                .forEach(el => el.classList.remove('selected', 'active'));

              wrapper.classList.add('selected', 'active');

              updateImagesForVariant(variantId);

              /* ⭐ Update selected variant name */
              updateVariantName(variantId);
            }

            wrapper.addEventListener('click', doSelect);
            wrapper.addEventListener('keydown', e => {
              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                doSelect();
              }
            });
          });

          /* Dropdown + Input Listener */
          const variantInputs = document.querySelectorAll('select[name="id"], input[name="id"]');
          variantInputs.forEach(inp => {
            inp.addEventListener('change', function () {
              const variantId = this.value;
              setActiveSwatchByVariantId(variantId);
              updateImagesForVariant(variantId);

              /* ⭐ Update selected variant name */
              updateVariantName(variantId);
            });
          });

          /* Initialize Default Variant */
          const initInput = document.querySelector('select[name="id"], input[name="id"]');
          if (initInput) {
            setActiveSwatchByVariantId(initInput.value);
            updateVariantName(initInput.value);
          }

        });
      })();
    </script>

  </variant-selects>
{%- endunless -%}
