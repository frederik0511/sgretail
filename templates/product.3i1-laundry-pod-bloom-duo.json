{"sections":{"custom_liquid_TMzBiR":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"{% comment %}\n  Breadcrumbs Section for Dawn Theme\n{% endcomment %}\n\n{% if template != 'index' and template != 'cart' %}\n<div class=\"breadcrumb-wrapper\">  \n  <nav class=\"breadcrumb\" role=\"navigation\" aria-label=\"breadcrumbs\">\n    <a href=\"{{ routes.root_url }}\" class=\"\">Home<\/a>\n\n    {% if template contains 'collection' and collection %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ collection.title }}<\/span>\n\n    {% elsif template contains 'product' and product %}\n      {% if product.collections.size > 0 %}\n        {% for coll in product.collections %}\n          <span class=\"mx-2\"> > <\/span>\n          <a href=\"{{ coll.url }}\" class=\"\">{{ coll.title }}<\/a>\n        {% endfor %}\n      {% endif %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ product.title }}<\/span>\n\n    {% elsif template contains 'article' and article %}\n      <span class=\"mx-2\"> > <\/span>\n      <a href=\"{{ blog.url }}\" class=\"\">{{ blog.title }}<\/a>\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ article.title }}<\/span>\n\n    {% elsif template contains 'page' and page %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>{{ page.title }}<\/span>\n\n    {% elsif template contains 'search' %}\n      <span class=\"mx-2\"> > <\/span>\n      <span>Search<\/span>\n    {% endif %}\n  <\/nav>\n<p class=\"product-sku\">\n  <strong>SKU:<\/strong> {{ product.selected_or_first_available_variant.sku }}\n<\/p>\n<\/div>\n{% endif %}\n\n\n\n<style>\n  .breadcrumb {\n    font-size: 0.9rem;\n    padding: 10px 20px;\n  }\n\n  .section-template--19466783981784__custom_liquid_TMzBiR-padding {\n    padding: 0 5rem;\n    max-width: 1599px;\n    margin: auto;\n  }\n\n  nav.breadcrumb {\n    font-family: 'Poppins';\n    font-size: 12px;\n    font-weight: 400;\n    color: #00514E;\n  }\n\n  nav.breadcrumb a {\n    font-family: 'Poppins';\n    font-size: 12px;\n    font-weight: 400;\n    color: #00514E;\n    text-decoration: none;\n  }\n<\/style>","color_scheme":"","padding_top":36,"padding_bottom":52}},"main":{"type":"main-product","blocks":{"title":{"type":"title","settings":{}},"icon_with_text_P4pPcy":{"type":"icon-with-text","settings":{"layout":"vertical","icon_1":"heart","image_1":"{{ product.metafields.custom.image_1.value }}","heading_1":"{{ product.metafields.custom.item_1.value }}","icon_2":"return","image_2":"{{ product.metafields.custom.image_2.value }}","heading_2":"{{ product.metafields.custom.item_2.value }}","icon_3":"truck","heading_3":""}},"icon_with_text_HzMMXX":{"type":"icon-with-text","settings":{"layout":"vertical","icon_1":"heart","image_1":"{{ product.metafields.custom.image_3.value }}","heading_1":"{{ product.metafields.custom.item_3.value }}","icon_2":"return","image_2":"{{ product.metafields.custom.image_4.value }}","heading_2":"{{ product.metafields.custom.item_4.value }}","icon_3":"truck","heading_3":""}},"price":{"type":"price","settings":{}},"variant_picker":{"type":"variant_picker","disabled":true,"settings":{"picker_type":"button","swatch_shape":"none"}},"custom_liquid_xM8DxJ":{"type":"custom_liquid","disabled":true,"settings":{"custom_liquid":"<div class=\"product-stock-status\">\n  {% if product.selected_or_first_available_variant.available %}\n    <span class=\"in-stock\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0720\/9130\/4152\/files\/check-svgrepo-com_1.png?v=1748879228\"\/> På Lager <span class=\"numbers-in-stock\">({{ product.selected_or_first_available_variant.inventory_quantity }})<\/span>\n    <\/span>\n  {% else %}\n    <span class=\"out-of-stock\">\n      ❌ Ikke på lager\n    <\/span>\n<div class=\"klaviyo-form-U8LeJ8\"><\/div>\n  {% endif %}\n<\/div>\n<Style>\n.in-stock{\nfont-size: 15px;\n    font-weight: 400;\n    color: #000;\n    font-family: 'Poppins';\ndisplay:flex;\nalign-items:center;\ngap:10px;\n}\nspan.in-stock img {\n    width: 20px;\n}\n<\/style>"}},"custom_liquid_WwCPLN":{"type":"custom_liquid","settings":{"custom_liquid":"{% render 'add-to-cart-btn' %}"}},"custom_liquid_rrzLC8":{"type":"custom_liquid","name":"Show Dynamic message","disabled":true,"settings":{"custom_liquid":"<p id=\"reward-message-prdDetail\" style=\"text-align:center; font-weight: bold; color: #fff; margin-top: 10px;margin-bottom:0px;\"><\/p>\n<script>\n  function updateProgressBarFromCart() {\n    fetch('\/cart.js')\n      .then(res => res.json())\n      .then(cart => {\n        const totalQty = cart.items.reduce((sum, item) => sum + item.quantity, 0);\n\n        \/\/ Calculate percentage fill and color\n        let percent = 0;\n        let fillColor = '#00514e'; \/\/ default\n\n        if (totalQty >= 2) {\n          percent = 25;\n          fillColor = 'rgb(255, 221, 72)';\n        }\n        if (totalQty >= 3) {\n          percent = 50;\n          fillColor = 'rgb(255, 221, 72)';\n        }\n        if (totalQty >= 4) {\n          percent = 75;\n          fillColor = 'rgb(255, 221, 72)';\n        }\n        if (totalQty >= 5) {\n          percent = 100;\n          fillColor = 'rgb(255, 221, 72)';\n\n        }\n\n \n       const fillEl = document.getElementById('progressFill');\n        const bgEl = document.querySelector('.progress-bar-background');\n        if (fillEl) {\n          fillEl.style.width = percent + '%';\n          fillEl.style.backgroundColor = fillColor;\n        }\n\n        \/\/ Change background color when full\n        if (bgEl) bgEl.style.backgroundColor = (percent === 100) ? '#ddd' : '#ddd';\n        \/\/ Update reward message\n        const msgEl = document.getElementById('reward-message');\n        const rewards = [\n          { qty: 2, reward: 'gratis frakt' },\n          { qty: 3, reward: '20 % rabatt' },\n          { qty: 4, reward: '25 % rabatt' },\n          { qty: 5, reward: '30 % rabatt' }\n        ];\n\n        if (msgEl) {\n          const next = rewards.find(r => totalQty < r.qty);\n          if (totalQty >= 5) {\n            msgEl.textContent = '🎉 Du har låst opp den beste belønningen!';\n          } else if (next) {\n            const remaining = next.qty - totalQty;\n            msgEl.textContent = `Legg til ${remaining} produkt ${remaining > 1 ? 's' : ''} til for å få ${next.reward}`;\n          } else {\n            msgEl.textContent = '';\n          }\n        }\n      });\n  }\n\n  \/\/ Initial update\n  document.addEventListener('DOMContentLoaded', updateProgressBarFromCart);\n  \n  \/\/ Listen for Shopify section reloads\n  document.addEventListener('shopify:section:load', updateProgressBarFromCart);\n  \n  \/\/ Custom event listener for AJAX cart updates\n  document.addEventListener('ajaxCart.afterCartUpdate', updateProgressBarFromCart);\n  \n  \/\/ Fallback polling every 2 seconds\n  setInterval(updateProgressBarFromCart, 2000);\n<\/script>"}},"quantity_selector":{"type":"quantity_selector","disabled":true,"settings":{}},"buy_buttons":{"type":"buy_buttons","disabled":true,"settings":{"show_dynamic_checkout":true,"show_gift_card_recipient":true}},"custom_liquid_TJXkN7":{"type":"custom_liquid","disabled":true,"settings":{"custom_liquid":"<div class=\"custom-accordion-wrapper\">\n  <button class=\"custom-accordion-toggle\" aria-expanded=\"false\">\n    <span class=\"custom-accordion-label\">Beskrivelse<\/span>\n    <span class=\"custom-toggle-text\">Les mer<\/span>\n  <\/button>\n  <div class=\"custom-accordion-content\">\n    <p>{{ product.description }}<\/p>\n  <\/div>\n<\/div>\n\n<style>\n.custom-accordion-wrapper {\n  border-radius: 6px;\n  margin-bottom: 20px;\n  overflow: hidden;\n}\n\n.custom-accordion-toggle {\n  width: 100%;\n  text-align: left;\n  padding: 15px;\n  font-weight: 400;\n  font-size: 20px;\n  cursor: pointer;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  background-color: #fff;\n  color: #00514E;\n  border: 1px solid #00514E;\n  transition: background-color 0.3s, color 0.3s;\n    border-radius: 10px;\n    \/\/border-top-left-radius: 10px;\n}\n\n.custom-accordion-toggle:hover {\n  background-color: #00514E;\n  color: #fff;\n}\n\n.custom-accordion-toggle:hover .custom-accordion-icon path {\n  stroke: #fff;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] {\n  background-color: #00514E;\n  color: #fff;\n  border-color: #00514E;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] .custom-accordion-icon path {\n  stroke: #fff;\n}\n\n.custom-accordion-icon {\n  transition: transform 0.3s ease;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] .custom-accordion-icon {\n  transform: rotate(45deg);\n}\n\n.custom-accordion-content {\n  display: none;\n  padding: 15px;\n  background-color: #fff;\n  border:1px solid #00541e;\nborder-bottom-left-radius: 10px;\n    border-bottom-right-radius: 10px;\n}\n\n.custom-accordion-toggle[aria-expanded=\"true\"] + .custom-accordion-content {\n  display: block;\n}\nspan.custom-accordion-label {\n    font-size: 18px;\n    font-weight: 400;\n    font-family: Poppins, sans-serif;\n}\n.custom-toggle-text{\nfont-size:14px;}\n<\/style>\n\n<script>\n  document.querySelectorAll('.custom-accordion-toggle').forEach(button => {\n    button.addEventListener('click', () => {\n      const isExpanded = button.getAttribute('aria-expanded') === 'true';\n\n      \/\/ Close all accordions first\n      document.querySelectorAll('.custom-accordion-toggle').forEach(btn => {\n        btn.setAttribute('aria-expanded', 'false');\n        btn.querySelector('.custom-toggle-text').textContent = 'Les mer';\n      });\n\n      if (!isExpanded) {\n        button.setAttribute('aria-expanded', 'true');\n        button.querySelector('.custom-toggle-text').textContent = 'Les mindre';\n      }\n    });\n  });\n<\/script>"}},"description":{"type":"description","disabled":true,"settings":{}},"share":{"type":"share","disabled":true,"settings":{"share_label":"Share"}}},"block_order":["title","icon_with_text_