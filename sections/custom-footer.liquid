<div class="custom-footer-section">
  <div class="custom-footer-inner">
    <!-- Column 1: Logo, Text, Social -->
    <div class="custom-footer-logo">
      {% if section.settings.footer_logo %}
        <img src="{{ section.settings.footer_logo | img_url: 'medium' }}" alt="Footer Logo">
      {% endif %}
      {% if section.settings.footer_text %}
        <p class="footer-para">{{ section.settings.footer_text }}</p>
      {% endif %}
      <div class="social-icons">
        {% if section.settings.facebook_url and section.settings.facebook_icon %}
          <a href="{{ section.settings.facebook_url }}" target="_blank">
            <img src="{{ section.settings.facebook_icon | img_url: 'original' }}" alt="Facebook Icon" width="24" height="24">
          </a>
        {% endif %}
        {% if section.settings.instagram_url and section.settings.instagram_icon %}
          <a href="{{ section.settings.instagram_url }}" target="_blank">
            <img src="{{ section.settings.instagram_icon | img_url: 'original' }}" alt="Instagram Icon" width="24" height="24">
          </a>
        {% endif %}
        {% if section.settings.twitter_url and section.settings.twitter_icon %}
          <a href="{{ section.settings.twitter_url }}" target="_blank">
            <img src="{{ section.settings.twitter_icon | img_url: 'original' }}" alt="Twitter Icon" width="24" height="24">
          </a>
        {% endif %}
      </div>
    </div>

    <!-- Columns 2 & 3: Menus -->
    {% for block in section.blocks %}
      {% if block.type == 'menu_column' %}
        <div class="custom-footer-menu">
          {% if block.settings.menu_title %}
            <h4>{{ block.settings.menu_title }}</h4>
          {% endif %}
          <ul>
            {% for link in linklists[block.settings.menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}

    <!-- Column 4: Contact -->
    <div class="custom-footer-contact">
      {% if section.settings.contact_title %}
        <h4>{{ section.settings.contact_title }}</h4>
      {% endif %}
      {% if section.settings.contact_phone and section.settings.contact_phone_icon %}
        <p>
          <img src="{{ section.settings.contact_phone_icon | img_url: 'original' }}" alt="Phone Icon" width="20" height="20">
          {{ section.settings.contact_phone }}
        </p>
      {% endif %}
      {% if section.settings.contact_email and section.settings.contact_email_icon %}
        <p>
          <img src="{{ section.settings.contact_email_icon | img_url: 'original' }}" alt="Email Icon" width="20" height="20">
          {{ section.settings.contact_email }}
        </p>
      {% endif %}
      
      {% if section.settings.contact_address and section.settings.contact_address_icon %}
        <p>
          <img src="{{ section.settings.contact_address_icon | img_url: 'original' }}" alt="Address Icon" width="20" height="20">
          {{ section.settings.contact_address }}
        </p>
      {% endif %}
      <div class="klaviyo-form-VHfb5f"></div>
