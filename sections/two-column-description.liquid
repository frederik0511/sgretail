{% comment %} for description {% endcomment %}
 (function () {
  const desc = document.querySelector('.two-col-desc__text.description');
  if (!desc) return;

  const maxHeight = 320; // collapsed height

  const fullHeight = desc.scrollHeight;
  if (fullHeight <= maxHeight) return;

  // Initial state
  desc.style.maxHeight = maxHeight + 'px';
  desc.style.overflow = 'hidden';
  desc.style.transition = 'max-height 0.3s ease';

  // Create button
  const toggle = document.createElement('button');
  toggle.className = 'see-toggle see-more';
  toggle.textContent = 'SE MER'; // Norwegian

  let expanded = false;

  toggle.addEventListener('click', function () {
    expanded = !expanded;

    if (expanded) {
      desc.style.maxHeight = fullHeight + 'px';
      toggle.textContent = 'SE MINDRE';
      toggle.classList.remove('see-more');
      toggle.classList.add('see-less');
    } else {
      desc.style.maxHeight = maxHeight + 'px';
      toggle.textContent = 'SE MER';
      toggle.classList.remove('see-less');
      toggle.classList.add('see-more');
    }
  });

  desc.after(toggle);
})();




