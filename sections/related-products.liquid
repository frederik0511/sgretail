      {% if settings.animations_reveal_on_scroll %}
        data-cascade
        style="--animation-order: {{ forloop.index }};"
      {% endif %} 
    >
      <!-- 🖼 Product Image -->
      <a href="{{ product.url }}" class="related-product-image" data-wash1="{{ product.metafields.custom.wash_price_1 }}">
        <img
          src="{{ product.featured_image | img_url: '400x' }}"
          alt="{{ product.title | escape }}"
          loading="lazy"
          width="300"
          height="300"
        />
        
        <div class="wash-price-badge">
          Pris per vask ned til {{ product.metafields.custom.wash_price_4 }} kr
        </div>
      
      </a>
<script>
  document.querySelectorAll('.related-product-image').forEach(el => {
  const wash1 = el.dataset.wash1;
  const wash2 = el.dataset.wash2;
  const wash3 = el.dataset.wash3;
  const wash4 = el.dataset.wash4;

  [wash1, wash2, wash3, wash4].forEach((val, i) => {
    if (val) {
      const badge = document.createElement('span');
      badge.className = 'wash-badge';
      badge.innerText = `${val} kr`;
      el.appendChild(badge);
    }
  });
});

</script>
