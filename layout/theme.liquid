    <script>




      
(function () {
  async function checkAndUpdatePrices() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      const totalQuantity = cart.items.reduce((sum, item) => sum + item.quantity, 0);

      const priceElements = document.querySelectorAll('span.price-item.price-item--regular, span.price-item.price-item--sale.price-item--last, p.modal-pricing, product-recommendations.related-products span.sale-price, span.price-item.price-item--sale.price-item--last, p.cart-item-price, .sticky-price-product-custom');

      const formatter = new Intl.NumberFormat('da-DK', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      });

      // Determine discount percentage based on quantity
      let discount = 0;
      if (totalQuantity >= 5) {
        discount = 0.25;
      } else if (totalQuantity >= 4) {
        discount = 0.20;
      } else if (totalQuantity >= 3) {
        discount = 0.15;
      } else if (totalQuantity >= 2) {
        discount = 0.10;
      }

      priceElements.forEach(el => {
        // const rawText = el.textContent.replace(/[^\d.,]/g, '').replace(',', '.');
        const rawText = el.textContent
        .replace(/[^\d,.-]/g, '')  // Strip NOK, spaces, currency symbols
        .replace(/\./g, '')        // Remove thousands separator
        .replace(',', '.');        // Convert decimal to JS format
        
        const originalPrice = parseFloat(el.dataset.originalPrice || rawText);

        if (discount > 0) {
          if (!el.dataset.originalPrice) {
            el.dataset.originalPrice = originalPrice;
          }
          const discounted = originalPrice * (1 - discount);
          el.innerHTML = `
            <span style="text-decoration: line-through; color: #5FB3C4; margin-right: 6px;" class="{{ product.title}}">
              ${formatter.format(originalPrice)} NOK
            </span>
            <span style="color: #00514E; font-weight: bold; class="{{ product.title}}">
              ${formatter.format(discounted)} NOK
            </span>
          `;
        } else if (el.dataset.originalPrice) {
          el.textContent = `${formatter.format(parseFloat(el.dataset.originalPrice))} NOK`;
          // el.textContent = formatter.format(parseFloat(el.dataset.originalPrice)) + ' NOK';
          delete el.dataset.originalPrice;
        }
      });

      console.log(`Checked cart. Total quantity: ${totalQuantity}, Discount: ${discount * 100}%`);
    } catch (error) {
      console.error('Error fetching cart:', error);
    }
  }

  checkAndUpdatePrices();
  setInterval(checkAndUpdatePrices, 1000);
})();





      
</script>


