                  opacity: 0;
                  transform: translateY(20px);
                }
                to {
                  opacity: 1;
                  transform: translateY(0);
                }
              }

            </style>

<script>

(function () {
  const grid = document.querySelector('#product-grid');
  if (!grid) return;

  let loading = false;
  let currentPage = 1;
  const totalPages = {{ paginate.pages }};

  function getNextPageUrl() {
    currentPage += 1;
    if (currentPage > totalPages) return null;

    const url = new URL(window.location.href);
    url.searchParams.set('page', currentPage);
    return url.toString();
  }

  function loadMoreProducts() {
    if (loading) return;

    const nextUrl = getNextPageUrl();
    if (!nextUrl) return;

    loading = true;

    fetch(nextUrl)
      .then(res => res.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const items = doc.querySelectorAll('#product-grid > li');

        if (!items.length) return;

        items.forEach(li => grid.appendChild(li));
        loading = false;
      })
      .catch(() => (loading = false));
  }

  // Sentinel
  const sentinel = document.createElement('div');
  sentinel.style.cssText = 'width:100%; height:40px; display:block;';
  const pagination = document.querySelector('.pagination');
  if (pagination) pagination.after(sentinel);

  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) loadMoreProducts();
  }, {
    rootMargin: '600px 0px',
    threshold: 0
  });

  observer.observe(sentinel);
})();
</script>



<script>
                    function increaseQty(btn) {
                      const input = btn.parentElement.querySelector('.qty-input');
                      input.value = parseInt(input.value) + 1;
                    }

