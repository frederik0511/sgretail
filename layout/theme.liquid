      <!-- CArt Drawer Refresh Code  -->

  <script>
  (function () {
    async function updateCartDrawer() {
      try {
        const res = await fetch('/cart.js');
        const cart = await res.json();

        const tbody = document.querySelector('#CartDrawer-CartItems .cart-items tbody');
        const totalEl = document.querySelector('.totals__total-value');

        if (!tbody) return;
        tbody.innerHTML = '';

        cart.items.forEach((item, index) => {
          const linePrice = (item.final_line_price / 100).toLocaleString('da-DK', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
          });

          const quantity = item.quantity;
          const originalPrice = (item.original_price / 100).toLocaleString('da-DK', {
            minimumFractionDigits: 2
          });

          const originalPriceWithQty = item.original_price / 100;
          const originalTotalPrice = (originalPriceWithQty * quantity).toLocaleString('da-DK', {
            minimumFractionDigits: 2
          });

          const discountMarkup = item.discounts.length > 0
            ? `<ul class="discounts list-unstyled" role="list" aria-label="Discounts">
                ${item.discounts.map(discount => `
                  <li class="discounts__discount">
                    <svg class="icon icon-discount" viewBox="0 0 12 12">
                      <path fill="currentColor" fill-rule="evenodd" d="M7 0h3a2 2 0 0 1 2 2v3a1 1 0 0 1-.3.7l-6 6a1 1 0 0 1-1.4 0l-4-4a1 1 0 0 1 0-1.4l6-6A1 1 0 0 1 7 0m2 2a1 1 0 1 0 2 0 1 1 0 0 0-2 0" clip-rule="evenodd"></path>
                    </svg>
                    ${discount.title}
                  </li>`).join('')}
              </ul>`
            : '';

          const row = `
            <tr class="cart-item" id="CartDrawer-Item-${index + 1}" role="row">
              <td class="cart-item__media" role="cell">
                <a href="${item.url}" class="cart-item__link" tabindex="-1" aria-hidden="true"></a>
                <img class="cart-item__image" src="${item.image}" alt="${item.title}" loading="lazy" width="150" height="150">
              </td>
              <td class="cart-item__details" role="cell">
                <a href="${item.url}" class="cart-item__name h4 break">${item.title}</a>
                <div class="product-option">${originalPrice} kr</div>
                ${item.options_with_values.map(opt => `
                  <div class="product-option">
                    <dt>${opt.name}:</dt>
                    <dd>${opt.value}</dd>
                  </div>`).join('')}
                ${discountMarkup}
              </td>
              <td class="cart-item__totals right" role="cell">
                <div class="cart-item__price-wrapper">
                <s class="cart-item__old-price price price--end two">
                                  ${originalTotalPrice} kr
                                </s>
                  <span class="price price--end">${linePrice} kr</span>
                </div>
              </td>
              <td class="cart-item__quantity" role="cell">
                <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                  <div class="quantity-popover-container">
                    <div class="quantity cart-quantity">
                      <button type="button" class="quantity__button" data-key="${item.key}" data-action="decrease">-</button>
                      <input class="quantity__input" type="number" value="${item.quantity}" min="1" readonly>
                      <button type="button" class="quantity__button" data-key="${item.key}" data-action="increase">+</button>
                    </div>
                    <cart-remove-button id="CartDrawer-Remove-${index + 1}" data-index="${index + 1}">
                      <button type="button" class="button button--tertiary cart-remove-button"
                              aria-label="Remove ${item.title}" data-variant-id="${item.variant_id}" data-key="${item.key}">
                        <span class="svg-wrapper">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-remove" viewBox="0 0 16 16">
                            <path fill="currentColor" d="M14 3h-3.53a3.07 3.07 0 0 0-.6-1.65C9.44.82 8.8.5 8 .5s-1.44.32-1.87.85A3.06 3.06 0 0 0 5.53 3H2a.5.5 0 0 0 0 1h1.25v10c0 .28.22.5.5.5h8.5a.5.5 0 0 0 .5-.5V4H14a.5.5 0 0 0 0-1M6.91 1.98c.23-.29.58-.48 1.09-.48s.85.19 1.09.48c.2.24.3.6.36 1.02h-2.9c.05-.42.17-.78.36-1.02m4.84 11.52h-7.5V4h7.5z"/>
                            <path fill="currentColor" d="M6.55 5.25a.5.5 0 0 0-.5.5v6a.5.5 0 0 0 1 0v-6a.5.5 0 0 0-.5-.5m2.9 0a.5.5 0 0 0-.5.5v6a.5.5 0 0 0 1 0v-6a.5.5 0 0 0-.5-.5"/>
                          </svg>
                        </span>
                      </button>
                    </cart-remove-button>
                  </div>
                </div>
              </td>
            </tr>
          `;

          tbody.insertAdjacentHTML('beforeend', row);
        });

        if (totalEl) {
          totalEl.textContent = (cart.total_price / 100).toLocaleString('da-DK', {
            minimumFractionDigits: 2
          }) + ' kr';
        }

        document.querySelectorAll('.quantity__button').forEach(button => {
          button.addEventListener('click', async () => {
            const key = button.dataset.key;
            const action = button.dataset.action;
            const input = button.parentElement.querySelector('.quantity__input');
            const currentQty = parseInt(input.value);
            let newQty = action === 'increase' ? currentQty + 1 : currentQty - 1;
            if (newQty < 1) newQty = 1;

            await fetch('/cart/change.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify({ id: key, quantity: newQty })
            });

            updateCartDrawer();
          });
        });

        document.querySelectorAll('.cart-remove-button').forEach(btn => {
          btn.addEventListener('click', async () => {
            const key = btn.dataset.key;
            await fetch('/cart/change.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
              },
              body: JSON.stringify({ id: key, quantity: 0 })
            });

            updateCartDrawer();
          });
        });

      } catch (err) {
        console.error('Error updating cart drawer:', err);
      }
    }

    updateCartDrawer();
    {% comment %} setInterval(updateCartDrawer, 1000); {% endcomment %}
  })();
  </script>

