            const hiddenSpan = bubble.querySelector('.visually-hidden');
            
            if (visibleSpan) visibleSpan.textContent = count;
            if (hiddenSpan) hiddenSpan.textContent = `${count} ${count === 1 ? 'item' : 'items'}`;
            
            bubble.style.display = count > 0 ? 'inline-block' : 'none';
          });
        } else {
          // Create cart bubble if it doesn't exist
          createCartBubble(count);
        }

        // Also update any cart icon text that shows count
        const cartIcons = document.querySelectorAll('.cart-count, .header__cart-count');
        cartIcons.forEach(icon => {
          icon.textContent = count;
          icon.style.display = count > 0 ? 'inline-block' : 'none';
        });
      })
      .catch(error => {
        console.error('Cart count update failed:', error);
      });
  }

  function createCartBubble(count) {
    const bubble = document.createElement('div');
    bubble.className = 'cart-count-bubble';
    bubble.innerHTML = `
      <span aria-hidden="true">${count}</span>
      <span class="visually-hidden">${count} ${count === 1 ? 'item' : 'items'}</span>
    `;
    bubble.style.display = count > 0 ? 'inline-block' : 'none';

    // Try different possible cart icon containers
    const cartContainers = [
      '.site-header__cart',
      '.header__icon--cart',
      '.cart-icon',
      '#cart-icon-bubble',
      '.header__icons [href*="/cart"]'
    ];

    for (const selector of cartContainers) {
      const container = document.querySelector(selector);
      if (container) {
        // Remove existing bubble if any
        const existingBubble = container.querySelector('.cart-count-bubble');
        if (existingBubble) existingBubble.remove();
        
        container.appendChild(bubble);
        break;
      }
    }
  }

  function refreshCartDrawer() {
