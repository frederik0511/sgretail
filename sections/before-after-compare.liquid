{% comment %} {% schema %}
{
  "name": "Before/After Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before Image",
      "info": "Recommended size: 1000x800px (use same dimensions for both images)"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After Image",
      "info": "Must match dimensions of Before Image"
    },
    {
      "type": "text",
      "id": "content_heading",
      "label": "Content Heading",
      "default": "See the Difference"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "Content Text",
      "default": "<p>Our product delivers visible results. Drag the slider to see the transformation.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 40,
      "max": 60,
      "step": 5,
      "unit": "%",
      "label": "Image Section Width",
      "default": 50
    },
    {
      "type": "select",
      "id": "image_aspect",
      "label": "Image Aspect Ratio",
      "options": [
        {
          "value": "4-3",
          "label": "4:3 (Standard)"
        },
        {
          "value": "16-9",
          "label": "16:9 (Widescreen)"
        },
        {
          "value": "1-1",
          "label": "1:1 (Square)"
        },
        {
          "value": "custom",
          "label": "Custom Height"
        }
      ],
      "default": "4-3"
    },
    {
      "type": "range",
      "id": "custom_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Custom Image Height",
      "default": 500,
      "info": "Only applies when Aspect Ratio is set to Custom Height"
    }
  ],
  "presets": [
    {
      "name": "Before/After Slider",
      "category": "Image"
    }
  ]
}
{% endschema %}

<div class="before-after-section page-width">
  <div class="before-after-container">
    <!-- Left Side - Slider -->
    <div class="before-after-slider-container" style="flex: {{ section.settings.image_width }};">
      <div class="before-after-slider aspect-ratio-{{ section.settings.image_aspect }}" {% if section.settings.image_aspect == 'custom' %}style="height: {{ section.settings.custom_height }}px;"{% endif %}>
        <img src="{{ section.settings.before_image | img_url: '1200x' }}" alt="Before" class="before-image">
        <div class="before-after-resize">
          <img src="{{ section.settings.after_image | img_url: '1200x' }}" alt="After" class="after-image">
        </div>
        <div class="before-after-handle">
          <span class="handle-arrow left">❮</span>
          <span class="handle-arrow right">❯</span>
        </div>
      </div>
    </div>
    
    <!-- Right Side - Content -->
    <div class="before-after-content" style="flex: {{ 100 | minus: section.settings.image_width }};">
      <div class="content-inner">
        {% if section.settings.content_heading != blank %}
          <h2 class="content-heading">{{ section.settings.content_heading }}</h2>
        {% endif %}
        
        {% if section.settings.content_text != blank %}
          <div class="content-text">
            {{ section.settings.content_text }}
          </div>
        {% endif %}
        
        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_link }}" class="button button--primary">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .before-after-section {
    padding: 60px 20px;
    max-width: 1600px;
    margin: 0 auto;
  }
  
  .before-after-container {
    display: flex;
    gap: 40px;
    align-items: center;
  }
  
  .before-after-slider-container {
    min-width: 300px;
  }
  
  /* Aspect Ratio Controls */
  .before-after-slider {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.1);
  }
  
  .aspect-ratio-4-3 {
    padding-top: 75%; /* 4:3 Aspect Ratio */
  }
  
  .aspect-ratio-16-9 {
    padding-top: 56.25%; /* 16:9 Aspect Ratio */
  }
  
  .aspect-ratio-1-1 {
    padding-top: 100%; /* Square */
  }
  
  .before-after-slider img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    pointer-events: none;
  }
  
  .before-after-resize {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 50%;
    overflow: hidden;
    border-right: 3px solid white;
  }
  
  .before-after-handle {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 46px;
    margin-left: -23px;
    cursor: ew-resize;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  
  .before-after-handle:before {
    content: "";
    position: absolute;
    width: 4px;
    height: 100%;
    background: white;
    box-shadow: 0 0 8px rgba(0,0,0,0.3);
  }
  
  .handle-arrow {
    background: white;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    box-shadow: 0 0 8px rgba(0,0,0,0.2);
    margin: 0 3px;
    color: #333;
  }
  
  /* Right Side Content Styles */
  .before-after-content {
    padding: 20px 0;
  }
  
  .content-inner {
    max-width: 500px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
.content-heading, h2.banner__heading.inline-richtext.h1 {
    font-size: 30px;
    margin-bottom: 20px;
    color: #000;
    line-height: 1.3;
    font-weight: 700;
}
  
  .content-text {
    font-size: 16px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 30px;
  }
  
  .content-text p {
    margin-bottom: 15px;
  }
  
  .content-text p:last-child {
    margin-bottom: 0;
  }
  
  /* Button Styles */
  .button {
    display: inline-block;
    padding: 12px 30px;
    border-radius: 4px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    text-align: center;
    background-color: #000;
    color: #fff;
    border: 2px solid #000;
  }
  
  .button:hover {
    background-color: #333;
    border-color: #333;
  }
  
  /* Responsive Styles */
  @media (max-width: 768px) {
    .before-after-container {
      flex-direction: column;
    }
    
    .before-after-slider-container,
    .before-after-content {
      flex: 1 1 100% !important;
      width: 100%;
    }
    
    .content-heading {
      font-size: 28px;
      margin-bottom: 15px;
    }
    
    .content-text {
      font-size: 15px;
      margin-bottom: 25px;
    }
    
    .button {
      padding: 10px 25px;
      font-size: 14px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const slider = document.querySelector('.before-after-slider');
  const resize = document.querySelector('.before-after-resize');
  const handle = document.querySelector('.before-after-handle');
  
  if (!slider || !resize || !handle) return;
  
  let isDragging = false;
  let startX, startWidth;
  
  function initSlider() {
    resize.style.width = '50%';
    handle.style.left = '50%';
  }
  
  function startDrag(e) {
    isDragging = true;
    startX = e.clientX || e.touches[0].clientX;
    startWidth = parseInt(resize.style.width, 10);
    document.body.style.cursor = 'ew-resize';
    document.body.style.userSelect = 'none';
    e.preventDefault();
  }
  
  function onDrag(e) {
    if (!isDragging) return;
    
    const sliderWidth = slider.offsetWidth;
    const currentX = e.clientX || e.touches[0].clientX;
    const diffX = currentX - startX;
    let newWidth = startWidth + (diffX / sliderWidth) * 100;
    
    // Constrain between 5% and 95%
    newWidth = Math.max(5, Math.min(95, newWidth));
    
    resize.style.width = `${newWidth}%`;
    handle.style.left = `${newWidth}%`;
  }
  
  function stopDrag() {
    isDragging = false;
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
  }
  
  // Initialize slider
  initSlider();
  
  // Mouse events
  handle.addEventListener('mousedown', startDrag);
  document.addEventListener('mousemove', onDrag);
  document.addEventListener('mouseup', stopDrag);
  
  // Touch events
  handle.addEventListener('touchstart', startDrag);
  document.addEventListener('touchmove', onDrag);
  document.addEventListener('touchend', stopDrag);
  
  // Prevent image drag
  const images = document.querySelectorAll('.before-after-slider img');
  images.forEach(img => {
    img.addEventListener('dragstart', (e) => e.preventDefault());
  });
});
</script> {% endcomment %}


