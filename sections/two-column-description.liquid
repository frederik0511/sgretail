  if (fullHeight <= COLLAPSED_HEIGHT) return;

  // Initial state
  desc.style.maxHeight = COLLAPSED_HEIGHT + 'px';
  desc.style.overflow = 'hidden';
  desc.style.transition = 'max-height 0.35s ease';

  // Wrapper
  const wrapper = document.createElement('div');
  wrapper.className = UNIQUE_WRAPPER;

  // Button
  const btn = document.createElement('button');
  btn.className = `${UNIQUE_BTN} ${STATE_MORE}`;
  btn.type = 'button';
  btn.textContent = 'SE MER'; // Norwegian

  let expanded = false;

  btn.addEventListener('click', function () {
    expanded = !expanded;

    if (expanded) {
      desc.style.maxHeight = fullHeight + 'px';
      btn.textContent = 'SE MINDRE';
      btn.classList.remove(STATE_MORE);
      btn.classList.add(STATE_LESS);
    } else {
      desc.style.maxHeight = COLLAPSED_HEIGHT + 'px';
      btn.textContent = 'SE MER';
      btn.classList.remove(STATE_LESS);
      btn.classList.add(STATE_MORE);
    }
  });

  wrapper.appendChild(btn);
  desc.after(wrapper);
})(); {% endcomment %}

(function uniqDescToggle_v2() {
  const TARGET_SELECTOR = '.two-col-desc__text.extra.info';
  const UNIQUE_WRAPPER = 'uniq-desc-toggle-wrap';
  const UNIQUE_BTN = 'uniq-desc-toggle-btn';
  const STATE_MORE = 'uniq-desc-more';
  const STATE_LESS = 'uniq-desc-less';

  const desc = document.querySelector(TARGET_SELECTOR);
  if (!desc || desc.classList.contains('uniq-desc-initialized')) return;

  desc.classList.add('uniq-desc-initialized');

  const COLLAPSED_HEIGHT = 320;
  const fullHeight = desc.scrollHeight;
  if (fullHeight <= COLLAPSED_HEIGHT) return;

  // Initial collapsed state
  desc.style.maxHeight = COLLAPSED_HEIGHT + 'px';
  desc.style.overflow = 'hidden';
  desc.style.transition = 'max-height 0.35s ease';

  // Wrapper
  const wrapper = document.createElement('div');
  wrapper.className = UNIQUE_WRAPPER;

  // Button
  const btn = document.createElement('button');
  btn.className = `${UNIQUE_BTN} ${STATE_MORE}`;
  btn.type = 'button';
  btn.textContent = 'SE MER';

  let expanded = false;

  btn.addEventListener('click', function () {
    expanded = !expanded;

    if (expanded) {
      // 🔓 OPEN → natural height
      desc.style.maxHeight = 'none';
      btn.textContent = 'SE MINDRE';
      btn.classList.remove(STATE_MORE);
      btn.classList.add(STATE_LESS);
    } else {
      // 🔒 CLOSE → collapsed height
      desc.style.maxHeight = COLLAPSED_HEIGHT + 'px';
      btn.textContent = 'SE MER';
      btn.classList.remove(STATE_LESS);
      btn.classList.add(STATE_MORE);
    }
  });

  wrapper.appendChild(btn);
  desc.after(wrapper);
})();

</script>
