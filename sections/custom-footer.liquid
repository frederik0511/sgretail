{% schema %}
{
  "name": "Custom Footer",
  "tag": "section",
  "class": "custom-footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer Text"
    },
    {
      "type": "header",
      "content": "Social Media Icons & Links"
    },
    {
      "type": "image_picker",
      "id": "facebook_icon",
      "label": "Facebook Icon"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "image_picker",
      "id": "instagram_icon",
      "label": "Instagram Icon"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "image_picker",
      "id": "twitter_icon",
      "label": "Twitter Icon"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter URL"
    },
    {
      "type": "header",
      "content": "Contact Details"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Contact Section Title",
      "default": "Contact Us"
    },
    {
      "type": "image_picker",
      "id": "contact_email_icon",
      "label": "Email Icon"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email"
    },
    {
      "type": "image_picker",
      "id": "contact_phone_icon",
      "label": "Phone Icon"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone"
    },
    {
      "type": "image_picker",
      "id": "contact_address_icon",
      "label": "Address Icon"
    },
    {
      "type": "text",
      "id": "contact_address",
      "label": "Address"
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "Menu Title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Custom Footer",
      "category": "Footer"
    }
  ]
}
{% endschema %}

{% stylesheet %}
.custom-footer-section {
  background-color: #F5F5F5;
  padding: 10px 20px;
}

.custom-footer-menu {
    padding-left: 25%;
}
.custom-footer-inner {
  max-width: 1600px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
  padding-bottom: 15px;
  border-bottom: 2px solid #00514E;
  padding-left: 50px;
  padding-right: 50px;
}

.custom-footer-logo {
  display: flex;
  flex-direction: column;
  gap: 0px;
}
p.footer-para {
    margin: 0 0 20px 0;
}
.custom-footer-logo img {
  max-width: 175px;
  height: auto;
}
p.footer-para {
    font-size: 13px;
}
.social-icons a img {
  margin-right: 10px;
  width: 40px;
  height: 40px;
}

.custom-footer-menu h4 {
  font-weight: 600;
  margin-bottom: 10px;
  font-size:14px;
}

.custom-footer-menu ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

/* .custom-footer-menu ul li {
  margin-bottom: 6px;
} */

.custom-footer-contact h4 {
font-weight: 600;
  margin-bottom: 10px;
  font-size:14px;
}
.custom-footer-menu a {
    font-size: 13px;
    color: #000;
    text-decoration: none;
    line-height: 30px;
}
.custom-footer-contact p {
  margin: 5px 0;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: #000;
}

.custom-footer-contact img {
  width: 20px;
  height: 20px;
}
  p.copyright {
    text-align: center;
    font-size: 14px;
    font-weight: 500;
    color: #121212bf;
        font-size: 13px;
    font-weight: 400;
}
  @media only screen and (max-width: 600px) {
 .custom-footer-inner {
    grid-template-columns: repeat(1, 1fr);
    padding-left: 0px;
    padding-right: 0px;
 }
    .custom-footer-menu {
    padding-left: 2%;
}
    .footer-bottom-wrapper {
    display: flex;
    flex-direction: column;
}
}
  .footer-bottom-wrapper {
    display: flex
;
    gap: 11%;
    justify-content: space-around;
    align-items: center;
    padding-top: 14px;
    max-width: 1600px;
    margin: auto;
}
  .payment-icon-wrapper {
    text-align: center;
}
  img.payment-icons {
