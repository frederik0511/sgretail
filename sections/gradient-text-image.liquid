{% comment %}
Section: Gradient Background + Two Columns
Left Column: Heading, Subheading, Paragraph, Button
Right Column: Image Upload
All editable in Theme Customizer
{% endcomment %}

<section class="gradient-section">
  <div class="gradient-container page-width">

    <div class="gradient-left">
           {% if section.settings.text != blank %}
        <h3>{{ section.settings.text }}</h3>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <h3>{{ section.settings.subheading }}</h3>
      {% endif %}
<img class="ribbon-img" src="https://cdn.shopify.com/s/files/1/0720/9130/4152/files/Group_8.png?v=1764868993">

   

      {% if section.settings.button_text != blank %}
        <div class="btn-slider-wrapper">
        <a href="{{ section.settings.button_link }}" class="gradient-btn">
          {{ section.settings.button_text }}
        </a>
        </div>
      {% endif %}
    </div>
    <div class="gradient-right">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | img_url: 'large' }}" alt="Section Image">
      {% endif %}
    </div>

  </div>
</section>


<style>
.gradient-section {
  background: linear-gradient(135deg, #FFFFFF, #5FB3C4);
  padding: 20px 0;
}

.gradient-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 40px;
}

.gradient-left h2 {
    font-size: 80px;
    text-align: end;
    font-weight: 700;
    color: #00514E;
    font-family: Barlow Condensed, sans-serif;
    margin:0px;
    text-align: center;
}

.gradient-left h3 {
    font-weight: 600;
    margin: 0;
    text-align: center;
    font-size: 42px;
    font-family: Barlow Condensed, sans-serif;
    color:#000;
}

{% comment %} .gradient-left p {
    font-size: 42px;
    text-align: center;
    font-weight: 600;
    font-family: Barlow Condensed, sans-serif;
     margin:0px;
     color:#000;
} {% endcomment %}

.gradient-btn {
    display: inline-block;
    padding: 6px 95px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 5px;
    font-size: 16px;
    transition: 0.3s;
    border-radius: 50px;
    font-weight: 700;
}
img.ribbon-img {
    width: 75%;
    margin-left: 13%;
}
.btn-slider-wrapper {
    display: flex;
    justify-content: center;
}
.gradient-btn:hover {
  opacity: 0.8;
}

.gradient-right img {
  width: 100%;
  height: auto;
  border-radius: 10px;
}

/* Responsive */
@media (max-width: 768px) {
  .gradient-container {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .gradient-left {
    order: 2;
  }

  .gradient-right {
    order: 1;
  }
}
</style>

{% schema %}
{
  "name": "Text Image Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Heading Here"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your Subheading Here"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Paragraph Text",
      "default": "Add your section description here."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Side Image"
    }
  ],
  "presets": [
    {
      "name": "Gradient Text + Image",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
