<script>
// SIMPLE BULLETPROOF VERSION - Remove ALL other scripts and use ONLY this one
document.addEventListener('DOMContentLoaded', function() {
  console.log('=== 🛒 PRODUCT FORM INITIALIZED ===');
  
  // Get the button directly
  const addToCartBtn = document.getElementById('AddToCart-{{ product.id }}');
  const form = document.getElementById('product-form-{{ product.id }}');
  
  if (!addToCartBtn) {
    console.error('❌ Add to cart button not found!');
    return;
  }
  
  console.log('✅ Add to cart button found:', addToCartBtn);
  console.log('✅ Form found:', !!form);

  // 1. Initialize quantity buttons (SIMPLE VERSION)
  function initQuantityButtons() {
    const plusBtn = document.querySelector('.quantity-btn.plus');
    const minusBtn = document.querySelector('.quantity-btn.minus');
    const qtyInput = document.querySelector('.product__quantity-input');
    
    if (plusBtn && minusBtn && qtyInput) {
      plusBtn.addEventListener('click', function() {
        qtyInput.value = parseInt(qtyInput.value) + 1;
      });
      
      minusBtn.addEventListener('click', function() {
        if (parseInt(qtyInput.value) > 1) {
          qtyInput.value = parseInt(qtyInput.value) - 1;
        }
      });
      
      console.log('✅ Quantity buttons initialized');
    }
  }

  // 2. Add to cart function (SIMPLE VERSION)
  async function addToCart() {
    console.log('🛒 Add to cart clicked!');
    
    // Get variant ID and quantity
    const variantInput = document.querySelector('input[name="id"]');
    const qtyInput = document.querySelector('input[name="quantity"]');
    
    if (!variantInput || !qtyInput) {
      console.error('❌ Missing variant ID or quantity input');
      return;
    }
    
    const variantId = variantInput.value;
    const quantity = parseInt(qtyInput.value) || 1;
    
    console.log('🛒 Adding to cart - Variant:', variantId, 'Quantity:', quantity);
    
    if (!variantId) {
      console.error('❌ Missing variant ID');
      alert('Feil: Mangler produktinformasjon');
      return;
    }

    // Lock UI
    const originalText = addToCartBtn.textContent;
    addToCartBtn.disabled = true;
    addToCartBtn.textContent = 'Legger til...';
    addToCartBtn.style.opacity = '0.7';

    try {
      console.log('🛒 Sending request to /cart/add.js...');
      
      // Add to cart - SIMPLE VERSION (same as your working script)
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ 
          id: variantId, 
          quantity: quantity 
        })
      });

      console.log('🛒 Response status:', response.status);
      
      if (!response.ok) {
        const errorText = await response.text();
        console.error('❌ Response not OK:', errorText);
        throw new Error('Kunne ikke legge i handlekurv');
      }

      const result = await response.json();
      console.log('✅ Product added successfully:', result);

      // Update cart count
      await updateCartCount();
      
      // Show success message
      showSuccessMessage();
      
    } catch (error) {
      console.error('❌ Add to cart error:', error);
      alert(error.message || 'Feil ved å legge produktet til i handlekurven');
    } finally {
      // Unlock UI
      addToCartBtn.disabled = false;
      addToCartBtn.textContent = originalText;
      addToCartBtn.style.opacity = '1';
    }
  }

  // 3. Update cart count
  async function updateCartCount() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      
      console.log('🛒 Cart updated, item count:', cart.item_count);
      
      // Update cart bubbles
      const bubbles = document.querySelectorAll('.cart-count-bubble');
      bubbles.forEach(bubble => {
        const visible = bubble.querySelector('span[aria-hidden="true"]');
        const hidden = bubble.querySelector('.visually-hidden');
        
        if (visible) visible.textContent = cart.item_count;
        if (hidden) hidden.textContent = `${cart.item_count} items`;
        
        if (cart.item_count > 0) {
          bubble.classList.remove('hidden');
        } else {
          bubble.classList.add('hidden');
        }
      });
      
    } catch (error) {
      console.error('⚠️ Error updating cart count:', error);
    }
  }

  // 4. Show success message
  function showSuccessMessage() {
    // Remove existing messages
    document.querySelectorAll('.cart-success-toast').forEach(el => el.remove());
    
    const toast = document.createElement('div');
    toast.className = 'cart-success-toast';
    toast.textContent = 'Lagt i handlekurven ✅';
    toast.style.cssText = `
      position: fixed;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      padding: 12px 24px;
      border-radius: 10px;
      background: #00514e;
      color: #fff;
      font-family: Poppins, sans-serif;
      font-weight: 600;
      z-index: 9999;
      box-shadow: 0 6px 20px rgba(0,0,0,.15);
      animation: toastSlideUp 0.3s ease-out;
    `;

    // Add animation styles
    if (!document.querySelector('#toast-animations')) {
      const style = document.createElement('style');
      style.id = 'toast-animations';
      style.textContent = `
        @keyframes toastSlideUp {
          from { transform: translateX(-50%) translateY(100px); opacity: 0; }
          to { transform: translateX(-50%) translateY(0); opacity: 1; }
        }
        @keyframes toastSlideDown {
          from { transform: translateX(-50%) translateY(0); opacity: 1; }
          to { transform: translateX(-50%) translateY(100px); opacity: 0; }
        }
      `;
      document.head.appendChild(style);
    }
    
    document.body.appendChild(toast);
    
    // Remove after 2 seconds
    setTimeout(() => {
      toast.style.animation = 'toastSlideDown 0.3s ease-in';
      setTimeout(() => toast.remove(), 300);
    }, 2000);
  }

  // 5. Out of stock check
  function checkOutOfStock() {
    const outOfStockElements = document.querySelectorAll('.out-of-stock, .sold-out');
    console.log('Out of stock elements found:', outOfStockElements.length);
    
    if (outOfStockElements.length > 0) {
      addToCartBtn.disabled = true;
      addToCartBtn.textContent = 'Utsolgt';
      addToCartBtn.style.cursor = 'not-allowed';
      addToCartBtn.style.opacity = '0.5';
      
      // Disable quantity controls
      document.querySelectorAll('.quantity-btn, .product__quantity-input').forEach(el => {
        el.disabled = true;
        el.style.opacity = '0.6';
        el.style.cursor = 'not-allowed';
      });
    }
  }

  // ===== INITIALIZE EVERYTHING =====
  
  // Initialize quantity buttons
  initQuantityButtons();
  
  // Check out of stock status
  checkOutOfStock();
  
  // Add click event to button (DIRECT APPROACH)
  addToCartBtn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();
    
    console.log('🛒 Button click captured!');
    addToCart();
  });

  // Also prevent form submission if it exists
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      e.stopPropagation();
      console.log('🛒 Form submission prevented, using button click instead');
      return false;
    });
  }

  console.log('=== ✅ PRODUCT FORM FULLY INITIALIZED ===');
});

// Make sure this runs even if DOMContentLoaded already fired
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  // DOM already loaded, initialize immediately
  setTimeout(() => {
    const addToCartBtn = document.getElementById('AddToCart-{{ product.id }}');
    if (addToCartBtn) {
      console.log('🛒 Late initialization');
      addToCartBtn.addEventListener('click', function(e) {
        e.preventDefault();
        alert('Add to cart would work here!');
      });
    }
  }, 100);
}
</script>



<script>
document.addEventListener('DOMContentLoaded', function() {
  // Initialize quantity buttons for all product forms
  function initializeQuantityButtons(form) {
    const plusBtn = form.querySelector('.quantity-btn.plus');
    const minusBtn = form.querySelector('.quantity-btn.minus');
    const qtyInput = form.querySelector('.product__quantity-input');
    
    if (plusBtn && minusBtn && qtyInput) {
      // Plus button click
      plusBtn.addEventListener('click', function() {
        let currentValue = parseInt(qtyInput.value) || 1;
        qtyInput.value = currentValue + 1;
        updateButtonState(form);
      });
      
      // Minus button click
      minusBtn.addEventListener('click', function() {
        let currentValue = parseInt(qtyInput.value) || 1;
        if (currentValue > 1) {
          qtyInput.value = currentValue - 1;
          updateButtonState(form);
        }
      });
      
      // Input validation
      qtyInput.addEventListener('change', function() {
        let value = parseInt(this.value) || 1;
        if (value < 1) value = 1;
        this.value = value;
        updateButtonState(form);
      });
      
      // Input keypress validation (only numbers)
      qtyInput.addEventListener('keypress', function(e) {
        const charCode = e.which ? e.which : e.keyCode;
        if (charCode < 48 || charCode > 57) {
          e.preventDefault();
          return false;
        }
        return true;
      });
    }
  }
  
  // Update button state based on quantity
  function updateButtonState(form) {
    const qtyInput = form.querySelector('.product__quantity-input');
    const minusBtn = form.querySelector('.quantity-btn.minus');
    const quantity = parseInt(qtyInput.value) || 1;
    
    // Enable/disable minus button based on quantity
    if (minusBtn) {
      if (quantity <= 1) {
        minusBtn.disabled = true;
        minusBtn.style.opacity = '0.5';
        minusBtn.style.cursor = 'not-allowed';
      } else {
        minusBtn.disabled = false;
        minusBtn.style.opacity = '1';
        minusBtn.style.cursor = 'pointer';
      }
    }
  }
  
  // Initialize all product forms on the page
  const productForms = document.querySelectorAll('.collectionAddCart form[data-type="add-to-cart-form"]');
  productForms.forEach(form => {
    initializeQuantityButtons(form);
    updateButtonState(form); // Set initial state
  });
  
  // Handle form submission to include quantity
  productForms.forEach(form => {
    form.addEventListener('submit', function(e) {
      // The quantity will be automatically included because it's a form input with name="quantity"
      console.log('🛒 Adding to cart with quantity:', form.querySelector('input[name="quantity"]')?.value);
    });
  });
});
</script>







