<script>
(function () {
  const hamburger = document.getElementById('desktopHamburger');
  const megaMenu = document.getElementById('MegaMenu-Content-');

  if (!hamburger || !megaMenu) return;

  hamburger.addEventListener('click', function (e) {
    e.preventDefault();
    e.stopPropagation();
    megaMenu.classList.toggle('is-open');
  });

  document.addEventListener('click', function (e) {
    if (!megaMenu.contains(e.target) && !hamburger.contains(e.target)) {
      megaMenu.classList.remove('is-open');
    }
  });
})();
</script>
<script>
(function () {
  const HAMBURGER_ID = 'desktopHamburger';
  const MEGA_MENU_ID = 'MegaMenu-Content-5';

  function init() {
    const hamburger = document.getElementById(HAMBURGER_ID);
    const megaMenu = document.getElementById(MEGA_MENU_ID);

    if (!hamburger || !megaMenu) return;

    const icon = hamburger.querySelector('span');

    function openMenu() {
      megaMenu.classList.add('is-open');
      icon.textContent = '✕';
    }

    function closeMenu() {
      megaMenu.classList.remove('is-open');
      icon.textContent = '☰';
    }

    function toggleMenu(e) {
      e.preventDefault();
      e.stopImmediatePropagation(); // 🔑 CRITICAL
      e.stopPropagation();

      if (megaMenu.classList.contains('is-open')) {
        closeMenu();
      } else {
        openMenu();
      }
    }

    /* Remove any existing handler to avoid duplicates */
    hamburger.onclick = null;

    /* Attach click in CAPTURE phase (before Shopify) */
    hamburger.addEventListener('click', toggleMenu, true);

    /* Outside click */
    document.addEventListener(
      'click',
      function (e) {
        if (
          megaMenu.classList.contains('is-open') &&
          !megaMenu.contains(e.target) &&
          !hamburger.contains(e.target)
        ) {
          closeMenu();
        }
      },
      true
    );
  }

  /* Init once DOM is ready */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


