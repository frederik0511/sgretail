<script>
let previousQty = null;
let previousPercent = 0;

function fireConfettiFromMascot(mascotEl) {
  if (!mascotEl) return;

  const rect = mascotEl.getBoundingClientRect();
  const x = (rect.left + rect.width / 2) / window.innerWidth;
  const y = (rect.top + rect.height / 2) / window.innerHeight;

  confetti({
    particleCount: 1000,
    spread: 60,
    startVelocity: 40,
    origin: { x, y }
  });
}

function updateProgressBarAndReward() {
  fetch('/cart.js')
    .then(res => res.json())
    .then(cart => {
      const totalQty = cart.items.reduce((sum, item) => sum + item.quantity, 0);
      const fillEl = document.getElementById('progressFill');
      const mascotEl = document.getElementById('flekkenMascot');

      // ✅ Only run confetti when qty increases (user adds product)
      if (previousQty !== null && totalQty > previousQty) {
        fireConfettiFromMascot(mascotEl);
      }

      // Save this qty for next run
      previousQty = totalQty;

      // ✅ Progress %
      let percent = 0;
      if (totalQty === 1) percent = 5;
      if (totalQty >= 2) percent = 25;
      if (totalQty >= 3) percent = 50;
      if (totalQty >= 4) percent = 75;
      if (totalQty >= 5) percent = 100;

      if (fillEl) {
        fillEl.style.width = percent + '%';
        fillEl.style.backgroundColor = '#5FB3C4';
      }

      // ✅ Reward message
      const msgEl = document.getElementById('reward-message');
      const rewards = [
        { qty: 2, reward: '10 % rabatt' },
        { qty: 3, reward: '15 % rabatt' },
        { qty: 4, reward: '20 % rabatt' },
        { qty: 5, reward: '25 % rabatt' }
      ];

      if (msgEl) {
        const next = rewards.find(r => totalQty < r.qty);
        if (totalQty >= 5) {
          msgEl.textContent = '🎉 Du har låst opp den beste belønningen!';
        } else if (next) {
          const remaining = next.qty - totalQty;
          msgEl.textContent = `Legg til ${remaining} produkt${remaining > 1 ? 'er' : ''} til å få ${next.reward}`;
        } else {
          msgEl.textContent = '';
        }
      }
    });
}

