
<section class="benefits-section">
        <h2>{{ section.settings.heading }}</h2>
      <p class="subtitle">{{ section.settings.subheading }}</p>
  <div class="benefits-inner">

    <!-- LEFT BENEFITS (DESKTOP) -->
    <div class="benefits-col benefits-left">
      {% for block in section.blocks %}
        {% if block.settings.position == 'left' %}
          <div class="benefit-item">
            <div class="icon">
              {% if block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="{{ block.settings.title }}">
              {% endif %}
            </div>
            <div class="text">
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- CENTER ICON -->
    <div class="benefits-image">
      {% if section.settings.center_icon != blank %}
        <img src="{{ section.settings.center_icon | image_url: width: 300 }}" alt="Center icon">
      {% endif %}
    </div>

    <!-- RIGHT BENEFITS (DESKTOP) -->
    <div class="benefits-col benefits-right">
      {% for block in section.blocks %}
        {% if block.settings.position == 'right' %}
          <div class="benefit-item">
            <div class="icon">
              {% if block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="{{ block.settings.title }}">
              {% endif %}
            </div>
            <div class="text">
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- MOBILE CONTENT -->
    <div class="benefits-mobile">
      <h2>{{ section.settings.heading }}</h2>
      <p class="subtitle">{{ section.settings.subheading }}</p>

      {% comment %} {% for block in section.blocks %}
        <div class="accordion-item">
          <button class="accordion-header">
            <span class="icon">{{ block.settings.icon }}</span>
            {{ block.settings.title }}
            <span class="toggle">+</span>
          </button>
          <div class="accordion-body">{{ block.settings.text }}</div>
        </div>
      {% endfor %} {% endcomment %}
       {% for block in section.blocks %}
  <div class="accordion-item">
    <button class="accordion-header">
      
      {% if block.settings.icon_image != blank %}
        <span class="icon">
          <img
            src="{{ block.settings.icon_image | image_url: width: 60 }}"
            alt="{{ block.settings.title }}"
            loading="lazy"
          >
        </span>
      {% endif %}

      <span class="title">{{ block.settings.title }}</span>

      <span class="toggle">+</span>
    </button>

    <div class="accordion-body">
      {{ block.settings.text }}
    </div>
  </div>
{% endfor %}

    </div>

  </div>
</section>

<style>
.benefits-section{padding:60px 10px}
.benefits-inner{display:grid;grid-template-columns:1fr 1fr 1fr;align-items:center;gap:30px;padding: 0px 0px;}
.benefits-col{display:flex;flex-direction:column;gap:50px}
{% comment %} .benefit-item{display:flex;align-items:center;gap:15px} {% endcomment %}
.benefit-item .icon{width:46px;height:46px;border-radius:50%;background:#0a5c53;color:#fff;display:flex;align-items:center;justify-content:center;font-size:20px}
{% comment %} .benefit-item h4{margin:0;font-size:16px} {% endcomment %}
 .benefit-item h4 {
    margin: 0;
    font-weight: bold;
    font-family: 'Barlow Condensed' !important;
    font-size: 24px;
    text-transform: uppercase;
    margin: 0px;
}
.benefits-col.benefits-left .text {
    text-align: end;
}
.benefits-col.benefits-right .benefit-item {
    display: flex;
    flex-direction: row;
    gap: 50px;
    align-items: center;
}
.benefits-col.benefits-left .benefit-item {
    display: flex;
    align-items: center;
    gap: 40px;
    flex-direction: row-reverse;
}
.benefits-col.benefits-right .benefit-item {
    display: flex;
}
.benefit-item p{margin:5px 0 0;font-size:14px;color:#555}
.benefits-image img{max-width:420px;width:100%}
section.benefits-section {
    max-width: 1500px;
    margin: auto;
}
section.benefits-section h2 {
    text-align: center;
    font-weight: bold;
    font-family: 'Barlow Condensed' !important;
    font-size: 36px;
    text-transform: uppercase;
    margin:0px;
}
p.subtitle {
    font-size: 16px;
    text-align: center;
    margin: 0;
    height:50px;
    color:#121212;
}
/* MOBILE */
.benefits-mobile{display:none}
@media(max-width:768px){
  .benefits-inner{grid-template-columns:1fr}
  .benefits-col{display:none}
  .benefits-image{text-align:center}
  .benefits-mobile{display:block;}
  .benefits-mobile h2{text-align:center;font-size:22px}
  .benefits-mobile .subtitle{text-align:center;margin-bottom:20px}
  .accordion-item{border:1px solid #051740;border-radius:12px;margin-bottom:16px}
  .accordion-header{width:100%;background:#fff;border:none;padding:14px;display:flex;align-items:center;justify-content:space-between;font-size:14px;font-weight:600;border-radius: 12px;}
  .accordion-header .icon{margin-right:10px}
  .accordion-body{display:none;padding:0 14px 14px;font-size:16px;color:#000}
  .title, .title-wrapper-with-link {
    margin: 0rem 0rem 0rem;
    font-size: 22px;
    font-family: 'Barlow Condensed';
}
span.icon img {
    width: 50px;
}
span.title {
    width: 100%;
    text-align: justify;
}
section.benefits-section, .benefits-inner {
    padding-bottom: 0;
}
.benefits-section{padding:30px 20px}
}
.benefits-col {
    gap: 70px;
}

.benefits-col.benefits-left .benefit-item:nth-child(1) {
    position: relative;
    left: 50px;
}
.benefits-col.benefits-left .benefit-item:nth-last-child(1) {
    position: relative;
    left: 50px;
}
.benefits-col.benefits-right .benefit-item:nth-child(1) {
    position: relative;
    right: 50px;
}
.benefits-col.benefits-right .benefit-item:nth-last-child(1) {
    position: relative;
    right: 50px;
}
.benefits-mobile h2, .benefits-mobile p {
    display: none;
}
</style>

<script>
document.addEventListener('click',function(e){
  if(!e.target.closest('.accordion-header')) return;
  const body = e.target.closest('.accordion-item').querySelector('.accordion-body');
  body.style.display = body.style.display === 'block' ? 'none' : 'block';
});
</script>

{% schema %}
{
  "name": "Benefits Product Section",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "FORDELENE VED FLEKKFRITT GULVVASKEARK"},
    {"type": "text", "id": "subheading", "label": "Subheading", "default": "Pletfri gulvrengøringsark"},
    {"type": "image_picker", "id": "center_icon", "label": "Center icon (image)"}
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {"type": "select", "id": "position", "label": "Desktop position", "options": [
          {"value": "left", "label": "Left"},
          {"value": "right", "label": "Right"}
        ], "default": "left"},
        {"type": "image_picker", "id": "icon_image", "label": "Icon image"},
        {"type": "text", "id": "title", "label": "Title"},
        {"type": "textarea", "id": "text", "label": "Text"}
      ]
    }
  ],
  "presets": [
    {"name": "Benefits Product"}
  ]
}
{% endschema %}
