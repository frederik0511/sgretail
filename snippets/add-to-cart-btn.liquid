      transform: translateX(-50%);
      padding: 12px 24px;
      border-radius: 10px;
      background: #00514e;
      color: #fff;
      font-family: Poppins, sans-serif;
      font-weight: 600;
      z-index: 9999;
      box-shadow: 0 6px 20px rgba(0,0,0,.15);
      animation: toastSlideUp 0.3s ease-out;
    `;

    // Add animation styles
    if (!document.querySelector('#toast-animations')) {
      const style = document.createElement('style');
      style.id = 'toast-animations';
      style.textContent = `
        @keyframes toastSlideUp {
          from { transform: translateX(-50%) translateY(100px); opacity: 0; }
          to { transform: translateX(-50%) translateY(0); opacity: 1; }
        }
        @keyframes toastSlideDown {
          from { transform: translateX(-50%) translateY(0); opacity: 1; }
          to { transform: translateX(-50%) translateY(100px); opacity: 0; }
        }
      `;
      document.head.appendChild(style);
    }
    
    document.body.appendChild(toast);
    
    // Remove after 2 seconds
    setTimeout(() => {
      toast.style.animation = 'toastSlideDown 0.3s ease-in';
      setTimeout(() => toast.remove(), 300);
    }, 2000);
  }

  // 5. Out of stock check
  function checkOutOfStock() {
    const outOfStockElements = document.querySelectorAll('.out-of-stock, .sold-out');
    console.log('Out of stock elements found:', outOfStockElements.length);
    
    if (outOfStockElements.length > 0) {
      addToCartBtn.disabled = true;
      addToCartBtn.textContent = 'Utsolgt';
      addToCartBtn.style.cursor = 'not-allowed';
      addToCartBtn.style.opacity = '0.5';
      
      // Disable quantity controls
      document.querySelectorAll('.quantity-btn, .product__quantity-input').forEach(el => {
        el.disabled = true;
        el.style.opacity = '0.6';
        el.style.cursor = 'not-allowed';
      });
    }
  }

  // ===== INITIALIZE EVERYTHING =====
  
  // Initialize quantity buttons
  initQuantityButtons();
  
  // Check out of stock status
  checkOutOfStock();
  
  // Add click event to button (DIRECT APPROACH)
  addToCartBtn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    e.stopImmediatePropagation();
    
    console.log('🛒 Button click captured!');
    addToCart();
  });

  // Also prevent form submission if it exists
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      e.stopPropagation();
      console.log('🛒 Form submission prevented, using button click instead');
      return false;
    });
  }

  console.log('=== ✅ PRODUCT FORM FULLY INITIALIZED ===');
});

// Make sure this runs even if DOMContentLoaded already fired
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else {
  // DOM already loaded, initialize immediately
  setTimeout(() => {
    {% comment %} const addToCartBtn = document.getElementById('AddToCart-{{ product.id }}'); {% endcomment %}
     const addToCartBtn = document.getElementById('add-to-cart-btn');
    if (addToCartBtn) {
      console.log('🛒 Late initialization');
      addToCartBtn.addEventListener('click', function(e) {
        e.preventDefault();
        alert('Add to cart would work here!');
      });
    }
  }, 100);
}
</script>

