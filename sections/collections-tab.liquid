      const showPagination = sliderElement.getAttribute('data-show-pagination') !== 'false';
      
      // Build unique class names
      const prevEl = sliderElement.querySelector('.collection-slider__button--prev');
      const nextEl = sliderElement.querySelector('.collection-slider__button--next');
      const paginationEl = sliderElement.querySelector('.collection-slider__pagination');
      
      // Swiper configuration
      const swiperConfig = {
