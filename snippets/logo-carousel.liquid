<style>
.logo-carousel-snippet {
  overflow: hidden;
  padding: 30px 0;
  background: #fff;
}

.logo-carousel-track {
  display: flex;
}

.logo-carousel-inner {
  display: flex;
  animation: scroll-marquee 40s linear infinite;
}

.logo-item {
  flex: 0 0 auto;
  margin: 0 40px;
}

.logo-item img {
  max-height: 60px;
  object-fit: contain;
  transition: transform 0.3s ease;
}
h2.related-products__heading.inline-richtext {
    text-align: center;
    font-size: 30px;
    font-weight: 700;
}
.logo-item img:hover {
  transform: scale(1.1);
}

@keyframes scroll-marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@media (max-width: 768px) {
  .logo-item { margin: 0 20px; }
  .logo-item img { max-height: 40px; }
}
</style>
