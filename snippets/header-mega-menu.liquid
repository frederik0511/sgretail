  font-family: 'Barlow Condensed';
  color: #000;
}

/* Responsive */
@media (max-width: 1024px) {
  .mega-menu-v2 {
    grid-template-columns: 1fr;
  }

  #MegaMenu-Content-5 {
    position: static;
    opacity: 1;
    visibility: visible;
    transform: none;
    pointer-events: auto;
