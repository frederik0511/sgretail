mage_with_text_7TPb64":{"type":"image-with-text","blocks":{"heading_k6eXTd":{"type":"heading","settings":{"heading":"Innovativ tørketeknologi – helt uten varme","heading_size":"h1"}},"text_B6HGPB":{"type":"text","settings":{"text":"<p>✓ Cool-Flow-teknologi med 6 kraftige vifter<br\/><br\/>✓ Sirkulerer luft jevnt for raskere tørking<br\/><br\/>✓ Ingen oppvarming – skånsom for tekstiler<br\/><br\/>✓ Forhindrer fukt og mugg i rommet<br\/><br\/>✓ Energieffektiv løsning for hverdagen<br\/><br\/>✓ Perfekt oppgradering for ditt tørkestativ<\/p>","text_style":"body"}}},"block_order":["heading_k6eXTd","text_B6HGPB"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/Oppgrader_-_Norsk_-_Post_f3993be3-2fac-4231-a7b1-0180ce074754.png","height":"medium","desktop_image_width":"medium","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":20,"padding_bottom":20}},"image_with_text_Vjd8UJ":{"type":"image-with-text","blocks":{"heading_PpcCVG":{"type":"heading","settings":{"heading":"Klar for å komme deg ut av tørkekrisen?","heading_size":"h1"}},"text_rWr979":{"type":"text","settings":{"text":"<p>✓ Raskere tørketid – halve tiden, dobbelt så effektiv<br\/><br\/>✓ Perfekt for små hjem og store kleshauger<br\/><br\/>✓ Passer under de fleste tørkestativ<br\/><br\/>✓ Stillegående og energibesparende<br\/><br\/>✓ Skånsom mot alle tekstiler<br\/><br\/>✓ Klar på 1-2-3 – plasser, trykk, slapp av<\/p>","text_style":"body"}}},"block_order":["heading_PpcCVG","text_rWr979"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/Sitter_du_fast_-_Norsk_-_Post.png","height":"medium","desktop_image_width":"medium","layout":"text_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":20,"padding_bottom":20}},"image_with_text_LMVkAF":{"type":"image-with-text","blocks":{"heading_B8bcwp":{"type":"heading","settings":{"heading":"Tørk tøyet raskt – uten å merke det på strømregninga","heading_size":"h1"}},"text_DadHQg":{"type":"text","settings":{"text":"<p>✓ HEYDRY bruker like lite strøm som en Wi-Fi-ruter<br\/><br\/>✓ Ideell for leiligheter og strømbevisste husholdninger<br\/><br\/>✓ Ingen varm luft – bare effektiv, skånsom tørk<br\/><br\/>✓ Perfekt for daglig bruk hele året<br\/><br\/>✓ God samvittighet for både miljø og lommebok<\/p><p>👉 HEYDRY – smartere tørk på 6 timer<\/p>","text_style":"body"}}},"block_order":["heading_B8bcwp","text_DadHQg"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/Tork_klaerne_raskt_-_Norsk_-_Post.png","height":"medium","desktop_image_width":"medium","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":20,"padding_bottom":20}},"accordion_with_image_f4YfYY":{"type":"accordion-with-image","blocks":{"accordion_RnTBw7":{"type":"accordion","settings":{"accordion_title":"Hva er HEYDRY laget av?","accordion_content":"Hva er HEYDRY laget av?\nHEYDRY er laget av høykvalitetsmaterialer med robust design for lang levetid. Produktet er utviklet i Tyskland og består av slitesterke plast- og metallkomponenter.\n\nEr HEYDRY miljøvennlig og resirkulerbar?\nJa, HEYDRY er designet med bærekraft i tankene. Den bruker opptil 90 % mindre energi enn tradisjonelle tørketromler, og mange av komponentene er resirkulerbare."}},"accordion_EEY3Ah":{"type":"accordion","settings":{"accordion_title":"Bruk og vedlikehold","accordion_content":"Hvordan bruker jeg HEYDRY for best tørkeresultat?\nPlasser HEYDRY under tørkestativet og sørg for at klærne ikke ligger oppå hverandre. Bruk riktig ventilasjon i rommet for å unngå fuktansamling.\nHvordan forhindrer jeg krymping av klær?\nHEYDRY bruker ikke varme, noe som gjør at klærne ikke krymper. Unngå overfylling av stativet for best resultat.\nHvordan unngår jeg at klær falmer?\nUnngå å tørke klær i direkte sollys, da UV-stråler kan bidra til falming.\nHvordan forhindrer jeg at klær mister formen?\nHeng klærne riktig, bruk kleshengere for skjorter og unngå å strekke tekstilene.\nHvordan rengjør jeg HEYDRY for optimal ytelse?\nTørk av enheten med en fuktig klut og fjern støv fra viftene regelmessig."}},"accordion_PwXAne":{"type":"accordion","settings":{"accordion_title":"Størrelse og kompatibilitet","accordion_content":"Passer HEYDRY til alle typer tørkestativer?\nJa, HEYDRY er designet for å være kompatibel med de fleste standard tørkestativer.\nHvilke mål har HEYDRY, og hvor mye veier den?\nHEYDRY måler 76 cm x 50 cm x 13 cm og veier 4,8 kg.\nEr HEYDRY egnet for små leiligheter?\nJa, HEYDRY er plassbesparende og enkel å oppbevare når den ikke er i bruk."}},"accordion_78q7yJ":{"type":"accordion","settings":{"accordion_title":"Vanlige problemer med produktet","accordion_content":"Hva gjør jeg hvis jeg ikke er fornøyd med HEYDRY?\n\nVi tilbyr retur innen 14 dager hvis du ikke er fornøyd.\nHEYDRY lager mer lyd enn forventet – er det normalt?\nStøynivået varierer avhengig av modus. Normal Mode er mer stillegående (~50 dB)."}},"accordion_pLzJRQ":{"type":"accordion","settings":{"accordion_title":"Levering og sporingsproblemer","accordion_content":"Bestillingen min viser at den er levert, men jeg har ikke mottatt den – hva gjør jeg?\nKontakt fraktselskapet eller vår kundeservice for assistanse.\nSender dere HEYDRY internasjonalt?\nIkke akkurat nå, kommer snart.\nHvor lang tid tar levering?\nLeveringstid avhenger av destinasjon, men tar vanligvis 2–7 virkedager."}}},"block_order":["accordion_RnTBw7","accordion_EEY3Ah","accordion_PwXAne","accordion_78q7yJ","accordion_pLzJRQ"],"disabled":true,"name":"Accordion With Image","settings":{"section_heading":"Ofte stilte spørsmål","section_image":"shopify:\/\/shop_images\/Spar_strom_-_Norsk.png"}},"collections_tab_Apmw4P":{"type":"collections-tab","blocks":{"tab_MbFth4":{"type":"tab","settings":{"tab_title":"Men","collection_list":["airpure-1","airpure","air-wick","1001-carpet-care"]}}},"block_order":["tab_MbFth4"],"custom_css":[".collection-tabs__nav {display: none;}","h2.collection-tabs__heading {margin-bottom: 3em;}",".collection-card {border-radius: 0; box-shadow: 0px 0px;}","@media screen and (max-width: 767px) {h2.collection-tabs__heading {margin-bottom: 15px !important; }}"],"name":"Collection Tabs with Slider","settings":{"heading":"BEDSTE VASKERIKATEGORIER","description":"","padding_top":36,"padding_bottom":60,"color_scheme":"background-1","desktop_grid":4,"tablet_grid":2,"mobile_grid":1,"slider_desktop":4,"slider_tablet":2,"slider_mobile":1,"slider_autoplay":false,"slider_autoplay_speed":3000,"show_navigation":true,"show_pagination":true}}},"order":["custom_liquid_TMzBiR","main","announcement_bar_raPL3a","two_column_description_zLchnN","benefits_product_hHUxDg","related-products","multicolumn_jMDgBf","custom_liquid_KYzanW","image_with_text_9NCEpj","image_with_text_QaafE4","image_with_text_jQpAmt","image_banner_H6jq3W","announcement_bar_YamXtR","custom_related_products_pbRfgc","image_with_text_MUG6aX","image_with_text_XV9Mcz","image_with_text_TtgYxJ","image_with_text_VhtVHW","image_with_text_ccD6jN","image_with_text_7TPb64","image_with_text_Vjd8UJ","image_with_text_LMVkAF","accordion_with_image_f4YfYY","collections_tab_Apmw4P"]}