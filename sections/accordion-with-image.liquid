{% schema %}
{
  "name": "Accordion With Image",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Right Side Image"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "accordion_title",
          "label": "Title",
          "default": "Accordion Title"
        },
        {
          "type": "textarea",
          "id": "accordion_content",
          "label": "Content",
          "default": "Accordion description goes here."
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Accordion With Image",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<div class="accordion-section-wrapper">
  <h2 class="accordion-heading text-center">{{ section.settings.section_heading }}</h2>
  <div class="accordion-layout">
    <div class="accordion-left">
      {% for block in section.blocks %}
        <div class="accordion-wrapper" {{ block.shopify_attributes }}>
          <button class="accordion-toggle" aria-expanded="false">
            <span>{{ block.settings.accordion_title }}</span>
            <svg class="accordion-icon" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5"/></svg>
          </button>
          <div class="accordion-content">
            <p>{{ block.settings.accordion_content }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="accordion-right">
      {% if section.settings.section_image != blank %}
        <img src="{{ section.settings.section_image | img_url: '600x' }}" alt="Accordion Image" />
      {% endif %}
    </div>
  </div>
</div>

<style>
.accordion-section-wrapper {
  max-width: 1300px;
  margin: 0 auto;
  padding: 40px 20px;
}
.accordion-heading {
  text-align: center;
  font-size: 2rem;
  margin-bottom: 40px;
}
.accordion-layout {
  display: flex;
  flex-wrap: wrap;
  gap: 30px;
}
.accordion-left {
  flex: 1;
  min-width: 300px;
}
.accordion-right {
  flex: 1;
  min-width: 300px;
}
.accordion-right img {
  width: 100%;
  height: auto;
  border-radius: 10px;
}

.accordion-wrapper {
  /* border: 1px solid #ddd; */
  border-radius: 6px;
  margin-bottom: 15px;
  overflow: hidden;
}
.accordion-toggle {
  width: 100%;
  text-align: left;
  padding: 15px;
  background-color: #f8f8f8;
  font-weight: 400;
  border: none;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.accordion-content {
  padding: 15px;
  display: none;
  background-color: white;
  border-top: 1px solid #ddd;
}
.accordion-toggle[aria-expanded="true"] + .accordion-content {
  display: block;
}
.accordion-icon {
  width: 16px;
  height: 16px;
  transition: transform 0.3s ease;
}
.accordion-toggle[aria-expanded="true"] .accordion-icon {
  transform: rotate(180deg);
}


  .accordion-wrapper {
  /* border: 1px solid #00514E; */
  border-radius: 6px;
  margin-bottom: 15px;
  overflow: hidden;
}

.accordion-toggle {
  width: 100%;
  text-align: left;
  background-color: #ffffff;
  font-weight: 400;
  border: none;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #00514e;
  transition: background-color 0.3s, color 0.3s;
  padding:20px !important;
  /* border-bottom: 1px solid #00514E; */
}

/* ✅ OPEN STATE STYLING */
.accordion-toggle[aria-expanded="true"] {
  background-color: #00514E;
  color: #ffffff;
}

.accordion-content {
  padding: 15px;
  display: none;
  background-color: #ffffff;
  color: #000000;
  transition: background-color 0.3s, color 0.3s;
  border-top: none;
}

/* ✅ WHEN OPEN, CHANGE CONTENT COLOR TO WHITE ON DARK BACKGROUND */
.accordion-toggle[aria-expanded="true"] + .accordion-content {
  display: block;
  background-color: #fff;

}
h2.accordion-heading.text-center {
    font-size: 30px;
    font-weight: bold;
}
/* Optional: rotate icon on open */
.accordion-icon {
  width: 16px;
  height: 16px;
  transition: transform 0.3s ease;
}

.accordion-toggle[aria-expanded="true"] .accordion-icon {
  transform: rotate(180deg);
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  document.querySelectorAll(".accordion-toggle").forEach(button => {
    button.addEventListener("click", () => {
      const isExpanded = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", !isExpanded);
    });
  });
});
</script>
