<div class="collection-tabs-section section-{{ section.id }}-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="collection-tabs__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if section.settings.description != blank -%}
      <div class="collection-tabs__description">{{ section.settings.description }}</div>
    {%- endif -%}
    
    {%- if section.blocks.size > 0 -%}
      <div class="collection-tabs">
        <!-- Tabs Navigation -->
        <div class="collection-tabs__nav">
          {%- for block in section.blocks -%}
            <button 
              class="collection-tabs__nav-item {% if forloop.first %}active{% endif %}" 
              data-tab="{{ block.id }}"
              data-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.tab_title }}
            </button>
          {%- endfor -%}
        </div>
        
        <!-- Tabs Content -->
        <div class="collection-tabs__content">
          {%- for block in section.blocks -%}
            {%- assign tab_id = 'tab-' | append: section.id | append: '-' | append: block.id -%}
            <div 
              class="collection-tabs__pane {% if forloop.first %}active{% endif %}" 
              id="{{ tab_id }}"
              data-tab-id="{{ block.id }}"
              data-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {%- assign collections_count = block.settings.collection_list.size -%}
              
              {%- if collections_count == 0 -%}
                <div class="collection-tabs__empty">
                  <p>No collections selected. Please add collections to this tab.</p>
                </div>
              {%- elsif collections_count <= 4 -%}
                <!-- Grid Layout for 1-4 collections -->
                <div class="collection-tabs__grid">
                  {%- for collection in block.settings.collection_list -%}
                    <div class="collection-card">
                      <a href="{{ collection.url }}" class="">
                        <div class="collection-card__image-wrapper">
                          {%- if collection.featured_image -%}
                            <img
                              src="{{ collection.featured_image | img_url: '600x' }}"
                              alt="{{ collection.title | escape }}"
                              class="collection-card__image"
                              loading="lazy"
                              width="600"
                              height="{{ 600 | divided_by: collection.featured_image.aspect_ratio | ceil }}"
                            >
                          {%- else -%}
                            {{ 'collection-1' | placeholder_svg_tag: 'collection-card__image collection-card__image--placeholder' }}
                          {%- endif -%}
                          
                          <div class="collection-card__overlay"></div>
                        </div>
                      </a>
                      
                      <a href="{{ collection.url }}" class="collection-card__content">
                        <span class="collection-card__title">{{ collection.title }}</span>
                        <svg class="collection-card__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M4.16669 10H15.8334M15.8334 10L10 4.16669M15.8334 10L10 15.8334" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </a>
                    </div>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <!-- Slider Layout for 5+ collections -->
                <div class="collection-tabs__slider">
                  <div class="collection-slider swiper-container-{{ tab_id }}" 
                       data-slider-id="{{ tab_id }}"
                       data-desktop-slides="{{ section.settings.slider_desktop }}"
                       data-tablet-slides="{{ section.settings.slider_tablet }}"
                       data-mobile-slides="{{ section.settings.slider_mobile }}"
                       data-autoplay="{{ section.settings.slider_autoplay }}"
                       data-autoplay-speed="{{ section.settings.slider_autoplay_speed }}"
                       data-show-navigation="{{ section.settings.show_navigation }}"
                       data-show-pagination="{{ section.settings.show_pagination }}">
                    <div class="swiper-wrapper">
                      {%- for collection in block.settings.collection_list -%}
                        <div class="swiper-slide">
                          <div class="collection-card">
                            <a href="{{ collection.url }}">
                              <div class="collection-card__image-wrapper">
                                {%- if collection.featured_image -%}
                                  <img
                                    src="{{ collection.featured_image | img_url: '600x' }}"
                                    alt="{{ collection.title | escape }}"
                                    class="collection-card__image"
                                    loading="lazy"
                                    width="600"
                                    height="{{ 600 | divided_by: collection.featured_image.aspect_ratio | ceil }}"
                                  >
                                {%- else -%}
                                  {{ 'collection-1' | placeholder_svg_tag: 'collection-card__image collection-card__image--placeholder' }}
                                {%- endif -%}
                                
                                <div class="collection-card__overlay"></div>
                              </div>
                            </a>
                            <a href="{{ collection.url }}" class="collection-card__content">
                              <span class="collection-card__title">{{ collection.title }}</span>
                              <svg class="collection-card__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M4.16669 10H15.8334M15.8334 10L10 4.16669M15.8334 10L10 15.8334" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </a>
                          </div>
                        </div>
                      {%- endfor -%}
                    </div>
                    
                    <!-- Slider Navigation -->
                    {%- if section.settings.show_navigation -%}
                      <div class="collection-slider__navigation">
                        <button class="collection-slider__button collection-slider__button--prev swiper-button-prev-{{ tab_id }}" aria-label="Previous slide">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </button>
                        <a href="collections/all" class="collections-all">Se alle nye produkter </a>
                        {%- if section.settings.show_pagination -%}
                          <div class="collection-slider__pagination swiper-pagination-{{ tab_id }}"></div>
                        {%- endif -%}
                        <button class="collection-slider__button collection-slider__button--next swiper-button-next-{{ tab_id }}" aria-label="Next slide">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </button>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- else -%}
      <div class="collection-tabs__empty-section">
        <p>No tabs added. Please add tabs with collections.</p>
      </div>
    {%- endif -%}
  </div>
</div>

