          <h2>${title}</h2>
          ${priceHTML}
          <p>${desc}</p>
          <form method="post" action="/cart/add" class="collection-add-to-cart-form" enctype="multipart/form-data">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <div class="quantity-add-wrapper">
              <div class="quantity-selector">
                <button type="button" class="qty-btn less" onclick="decreaseQty(this)">−</button>
                <input type="text" name="quantity" min="1" value="1" class="qty-input" />
                <button type="button" class="qty-btn add" onclick="increaseQty(this)">+</button>
              </div>
              <button type="submit" class="add-to-cart-btn">
                Legg i handlekurv
              </button>
            </div>
          </form>
          <div class="accordion">
            <button class="accordion-toggle">
              Product Description <span class="accordion-icon">+</span>
            </button>
            <div class="accordion-content" style="display:none;">
              <p>${desc}</p>
            </div>
          </div>
        </div>
      `);
      $('#quickInfoModal').fadeIn();
    });

    $('.close-btn').on('click', function () {
      $('#quickInfoModal').fadeOut();
    });

    $(document).on('click', function (e) {
      if ($(e.target).is('#quickInfoModal')) {
        $('#quickInfoModal').fadeOut();
      }
    });

    // Accordion toggle
    $(document).on('click', '.accordion-toggle', function () {
      $(this).toggleClass('active');
      const content = $(this).next('.accordion-content');
      if (content.is(':visible')) {
        content.stop(true, true).slideUp(200);
        $(this).css({ background: '#fff', color: '#000' });
      } else {
        $('.accordion-content').slideUp(200);
        $('.accordion-toggle').css({ background: '#fff', color: '#000' });
        content.stop(true, true).slideDown(200);
        $(this).css({ background: '#00514E', color: '#fff' });
      }
    });
  });
</script>

