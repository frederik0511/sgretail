nded', 'true');\n        button.querySelector('.custom-toggle-text').textContent = 'Les mindre';\n      }\n    });\n  });\n<\/script>"}},"description":{"type":"description","disabled":true,"settings":{}},"share":{"type":"share","disabled":true,"settings":{"share_label":"Share"}}},"block_order":["title","icon_with_text_P4pPcy","icon_with_text_HzMMXX","price","variant_picker","custom_liquid_xM8DxJ","custom_liquid_WwCPLN","quantity_selector","buy_buttons","custom_liquid_TJXkN7","description","share"],"settings":{"enable_sticky_info":true,"color_scheme":"scheme-1","media_size":"large","constrain_to_viewport":true,"media_fit":"contain","gallery_layout":"thumbnail_slider","mobile_thumbnails":"hide","media_position":"left","image_zoom":"lightbox","hide_variants":true,"enable_video_looping":false,"padding_top":36,"padding_bottom":12}},"announcement_bar_ggFXfW":{"type":"announcement-bar","blocks":{"announcement_xhHq4z":{"type":"announcement","settings":{"text":"LEGG I HANDLEKURVEN OG LÅS OPP RABATTENE","icon":"shopify:\/\/shop_images\/Img_-_icon_margin.png"}},"announcement_AhYFKe":{"type":"announcement","settings":{"text":"SPAR OPPTIL 30 PROSENT RABATT","icon":"shopify:\/\/shop_images\/Img_-_icon_margin.png"}},"announcement_Lwzmax":{"type":"announcement","settings":{"text":"PLUKK OG MIKS FAVORITTPRODUKTER FÅ ALT TIL 30% RABATT","icon":"shopify:\/\/shop_images\/Img_-_icon_margin.png"}},"announcement_eCCQmq":{"type":"announcement","settings":{"text":"LEGG I HANDLEKURVEN OG LÅS OPP RABATTENE","icon":"shopify:\/\/shop_images\/Img_-_icon_margin.png"}}},"block_order":["announcement_xhHq4z","announcement_AhYFKe","announcement_Lwzmax","announcement_eCCQmq"],"disabled":true,"custom_css":[".scrolling-announcement-wrapper {background: linear-gradient(to right, #5fb3c4, #00514e);}","img.scrolling-icon {width: 20px;}",".scrolling-item {font-size: 13px;}"],"name":"Scrolling Announcement","settings":{}},"two_column_description_yR9cht":{"type":"two-column-description","disabled":true,"name"