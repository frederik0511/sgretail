      button.classList.add('active');
      
      // Find and show corresponding pane
      const activePane = this.sectionElement.querySelector(`[data-tab-id="${tabId}"]`);
      if (activePane) {
        activePane.classList.add('active');
        this.initSliderForTab(activePane);
      }
    },
    
    initSliderForTab: function(tabElement) {
      const sliderElement = tabElement.querySelector('.collection-slider');
      
      if (!sliderElement) return;
      
      const sliderId = sliderElement.getAttribute('data-slider-id');
      
      // Destroy existing swiper instance if it exists
      if (this.swiperInstances[sliderId]) {
