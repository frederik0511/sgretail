{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image"
        },
        {
  "type": "text",
  "id": "mp4_video_url",
  "label": "MP4 Video URL (optional)"
},
        {
          "type": "video_url",
          "id": "background_video",
          "label": "YouTube Video URL (optional)",
          "accept": ["youtube"]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Welcome to Our Store"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "Shop the best products with confidence."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}

<div class="hero-slider-wrapper">
  <div class="hero-slider" id="heroSlider">
    {% for block in section.blocks %}
      <div class="hero-slide{% if forloop.first %} active{% endif %}">
        
        {% if block.settings.mp4_video_url != blank %}
          <video autoplay muted loop playsinline class="hero-media">
            <source src="{{ block.settings.mp4_video_url }}" type="video/mp4">
          </video>
        
        {% elsif block.settings.background_video != blank %}
          {% assign video_url = block.settings.background_video %}
          {% if video_url contains "youtu.be" %}
            {% assign video_id = video_url | split: "/" | last %}
          {% elsif video_url contains "watch?v=" %}
            {% assign video_id = video_url | split: 'v=' | last | split: '&' | first %}
          {% elsif video_url contains "youtube.com/embed/" %}
            {% assign video_id = video_url | split: "/embed/" | last | split: "?" | first %}
          {% else %}
            {% assign video_id = "" %}
          {% endif %}

          {% if video_id != blank %}
            <iframe
              src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&loop=1&playlist={{ video_id }}&controls=0&showinfo=0&rel=0"
              frameborder="0"
              allow="autoplay; fullscreen"
              allowfullscreen
              class="hero-media"
            ></iframe>
          {% endif %}

        {% elsif block.settings.background_image != blank %}
          <img src="{{ block.settings.background_image | image_url: width: 2000 }}" alt="Slide image" class="hero-media">
        {% endif %}

        <div class="hero-content">
          <h2>{{ block.settings.heading }}</h2>
          <p>{{ block.settings.subtext }}</p>
          {% if block.settings.button_label != blank and block.settings.button_link != blank %}
            <a href="{{ block.settings.button_link }}" class="hero-button">{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <button class="hero-arrow prev" onclick="slidePrev()">&#10094;</button>
  <button class="hero-arrow next" onclick="slideNext()">&#10095;</button>
</div>

<style>
.hero-slider-wrapper {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.hero-slider {
  display: flex;
  transition: transform 0.8s ease-in-out;
  width: 100%;
}

.hero-slide {
  min-width: 100%;
  height: 600px;
  position: relative;
  display: none;
  justify-content: center;
  align-items: center;
}

.hero-slide.active {
  display: flex;
}

.hero-media {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: white;
  padding: 20px;
  background: rgba(0,0,0,0.4);
  border-radius: 10px;
  max-width: 90%;
}
@media screen and (max-width: 768px) {
  .hero-content {
  z-index: 1;
}
}
.hero-content h2 {
  font-size: 48px;
  margin-bottom: 10px;
}

.hero-content p {
  font-size: 20px;
  margin-bottom: 20px;
}

.hero-button {
  display: inline-block;
  padding: 12px 24px;
  background: #fff;
  color: #000;
  text-decoration: none;
  font-weight: bold;
  border-radius: 5px;
}

.hero-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(0,0,0,0.3);
  color: #fff;
  border: none;
  font-size: 32px;
  cursor: pointer;
  padding: 10px 15px;
  z-index: 3;
}

.hero-arrow.prev {
  left: 20px;
}

.hero-arrow.next {
  right: 20px;
}
</style>

<script>
  let currentIndex = 0;
  const slides = document.querySelectorAll('#heroSlider .hero-slide');
  const total = slides.length;

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.classList.toggle('active', i === index);
    });
  }

  function slideNext() {
    currentIndex = (currentIndex + 1) % total;
    showSlide(currentIndex);
  }

  function slidePrev() {
    currentIndex = (currentIndex - 1 + total) % total;
    showSlide(currentIndex);
  }

  // Auto-play every 5 seconds
  setInterval(() => {
    slideNext();
  }, 5000);

  // Initialize
  showSlide(currentIndex);
</script>
