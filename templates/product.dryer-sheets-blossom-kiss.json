"padding_top":20,"padding_bottom":20}},"image_with_text_LMVkAF":{"type":"image-with-text","blocks":{"heading_B8bcwp":{"type":"heading","settings":{"heading":"Når mykhet og velvære møtes i tørketrommelen","heading_size":"h1"}},"text_DadHQg":{"type":"text","settings":{"text":"<p>✓ Etterlater tøyet mykt og behagelig<br\/><br\/>✓ Gjør klærne lettere å brette og bruke<br\/><br\/>✓ Skånsom mot tekstiler<br\/><br\/>✓ Subtil og ren duft <br\/><br\/>✓ Klar til bruk – legg rett i trommelen<br\/><br\/>✓ Enkle ark – ingen søl<\/p>","text_style":"body"}}},"block_order":["heading_B8bcwp","text_DadHQg"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/3_2.png","height":"medium","desktop_image_width":"medium","layout":"image_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content_alignment":"left","section_color_scheme":"","color_scheme":"","padding_top":20,"padding_bottom":20}},"accordion_with_image_f4YfYY":{"type":"accordion-with-image","blocks":{"accordion_RnTBw7":{"type":"accordion","settings":{"accordion_title":"Er Flekkfritt Tørketrommelark trygge å bruke i alle tørketromler?","accordion_content":"Ja. Flekkfritt Tørketrommelark er utviklet for å være trygge i både vanlige og moderne tørketromler. Arkene brukes direkte sammen med vått tøy og løser seg ikke opp, men fordeler duften og mykheten under tørkeprosessen."}},"accordion_EEY3Ah":{"type":"accordion","settings":{"accordion_title":"Fungerer Flekkfritt Tørketrommelark på vanskelig skitt og flekker?","accordion_content":"Nei. Dryer sheets er ikke laget for å fjerne skitt eller flekker – de brukes i tørketrommelen etter at klærne er vasket. Deres funksjon er å gjøre tøyet mykere, redusere statisk elektrisitet og tilføre en mild duft."}},"accordion_PwXAne":{"type":"accordion","settings":{"accordion_title":"Er Flekkfritt Tørketrommelark egnet for barneklær og tekstiler?","accordion_content":"Flekkfritt Tørketrommelark er laget uten fosfater, parabener, fargestoffer og klorbaserte blekemidler. Arkene legges direkte i tørketrommelen, og hudkontakten er begrenset til håndtering ved bruk. De er milde mot tekstiler og egner seg for klær, håndklær og sengetøy.\n\nMerk: Produktet inneholder kostusrotolje, som kan gi allergisk reaksjon hos sensitive personer."}},"accordion_78q7yJ":{"type":"accordion","settings":{"accordion_title":"Hvordan bidrar Flekkfritt Tørketrommelark til et mer bærekraftig valg?","accordion_content":"Flekkfritt Tørketrommelark leveres i resirkulerbar og plastfri emballasje. Det gir mindre avfall, enklere sortering hjemme og et mer bevisst valg i hverdagen."}},"accordion_pLzJRQ":{"type":"accordion","settings":{"accordion_title":"Hva slags duft etterlater Flekkfritt tørketrommelark på klærne?","accordion_content":"Flekkfritt er utviklet med en mildere formel enn mange tradisjonelle vaskemidler. Det betyr at duften etter vask er lett og diskret – et godt valg for deg som foretrekker klær uten sterk lukt eller er sensitiv for kraftige parfymer."}}},"block_order":["accordion_RnTBw7","accordion_EEY3Ah","accordion_PwXAne","accordion_78q7yJ","accordion_pLzJRQ"],"disabled":true,"name":"Accordion With Image","settings":{"section_heading":"Ofte stilte spørsmål","section_image":"shopify:\/\/shop_images\/Blossom_Kiss.png"}},"collections_tab_rBKe6n":{"type":"collections-tab","blocks":{"tab_hLQUhJ":{"type":"tab","settings":{"tab_title":"Men","collection_list":["airpure-1","airpure","air-wick","1001-carpet-care"]}}},"block_order":["tab_hLQUhJ"],"custom_css":[".collection-tabs__nav {display: none;}","h2.collection-tabs__heading {margin-bottom: 3em;}",".collection-card {border-radius: 0; box-shadow: 0px 0px;}","@media screen and (max-width: 767px) {h2.collection-tabs__heading {margin-bottom: 15px !important; }}"],"name":"Collection Tabs with Slider","settings":{"heading":"BEDSTE VASKERIKATEGORIER","description":"","padding_top":36,"padding_bottom":60,"color