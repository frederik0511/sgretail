ss=\"product-form\">\n  <input type=\"hidden\" name=\"id\" value=\"{{ product.variants.first.id }}\">\n\n  <div class=\"quantity-add-container\">\n    <div class=\"quantity-wrapper\">\n      <button type=\"button\" class=\"quantity-btn minus\">−<\/button>\n      <input\n        type=\"text\"\n        name=\"quantity\"\n        id=\"Quantity-{{ section.id }}\"\n        value=\"1\"\n        min=\"1\"\n        class=\"product__quantity-input\"\n      >\n      <button type=\"button\" class=\"quantity-btn plus\">+<\/button>\n    <\/div>\n\n    <button type=\"submit\" name=\"add\" class=\"product__add-to-cart-button\">\n      Legg i handlekurv\n    <\/button>\n  <\/div>\n<\/form>\n<Style>\n.quantity-add-container {\n  display: flex;\n  gap: 15px;\n  align-items: center;\n}\ninput#Quantity-template--19466783981784__main {\n    font-family: Poppins, sans-serif;\n    font-size: 21px;\n    font-weight: 500;\n}\n.quantity-wrapper {\n    display: flex;\n    flex: 22%;\n    align-items: center;\n    border: 1px solid #00514E;\n    border-radius: 10px;\n    overflow: hidden;\n    height: 61px;\n}\nbutton.quantity-btn.plus {\n    border-left: 1px solid #00514e;\nbackground-color: #fff;\n}\nbutton.quantity-btn.minus {\n    border-right: 1px solid #00514e;\nbackground-color: #fff;\n}\n.quantity-btn {\n  color: #fff;\nbackground-color:#00514e !Important;\n  border: none;\n  width: 32px;\n  height: 61px;\n  font-size: 25px;\n  cursor: pointer;\n}\n\n.product__quantity-input {\n  width: 60px;\n  text-align: center;\n  border: none;\n  height: 60px;\n}\n\nbutton.product__add-to-cart-button {\n    font-size: 20px;\n    width: 100%;\n    color: #fff;\n    background-color: #00514E;\n    line-height: 57px;\n    border-radius: 15px;\n    font-family: Poppins, sans-serif;\n    font-weight: 600;\ncursor:pointer;\n}\np.product-sku, p.product-category {\n    margin: 0;\n    color: #00514E;\n    font-family: Poppins, sans-serif;\n}\n.prdCardImgWrapper .paymentbadge {\n    width: 24%;\n}\n\n.prdCardImgWrapper .paymentbadge1 {\n    width: 42%;\n}\n.prdCardImgWrapper {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n<\/style>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    const container = document.querySelector('.quantity-add-container');\n    if (!container) return;\n\n    container.querySelector('.plus').addEventListener('click', () => {\n      const input = container.querySelector('.product__quantity-input');\n      input.value = parseInt(input.value || 1) + 1;\n    });\n\n    container.querySelector('.minus').addEventListener('click', () => {\n      const input = container.querySelector('.product__quantity-input');\n      if (parseInt(input.value) > 1) {\n        input.value = parseInt(input.value) - 1;\n      }\n    });\n  });\n<\/script>","color_scheme":"","padding_top":12,"padding_bottom":12}},"image_with_text_MUG6aX":{"type":"image-with-text","blocks":{"heading_TrVURa":{"type":"heading","settings":{"heading":"Slik bruker du Flekkfritt pods","heading_size":"h1"}},"text_G8rRUh":{"type":"text","settings":{"text":"<p>1. Legg kapselen direkte i trommelen. Ikke klipp eller åpne den på forhånd.<\/p><p>2. Fyll på med skittent tøy som vanlig.<br\/>3. Velg ønsket vaskeprogram.<br\/><\/p><p>✓ Slipp søl og tunge flasker<br\/><br\/>✓ Kompakt og plastfri emballasje<br\/><br\/>✓ Effektiv mot flekker – mild formel<br\/><br\/>✓ Praktisk hjemme og på reise<\/p>","text_style":"body"}}},"block_order":["heading_TrVURa","text_G8rRUh"],"custom_css":[".image-with-text .grid__item .image-with-text__media > img {object-fit: contain;}",".image-with-text .grid__item .image-with-text__media {border: 0;}"],"name":"t:sections.image-with-text.presets.name","settings":{"image":"shopify:\/\/shop_images\/105.png","height":"medium","desktop_image_width":"medium","layout":"text_first","image_behavior":"none","content_layout":"no-overlap","desktop_content_position":"middle","desktop_content_alignment":"left","mobile_content