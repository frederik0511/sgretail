    const targetDiv2 = document.querySelector('.price__container');
    if (targetDiv2) {
      const badge3 = document.createElement('div');
      badge3.className = 'wash-price-text-2';
      badge3.textContent = "Pris per vask ned til " + washPrice;
      targetDiv2.insertAdjacentElement('afterend', badge3);
    }
  }

  // ---------- COLLECTIONS / RELATED PRODUCTS ----------
  function addWashBadges() {
    const cardMediaDivs = document.querySelectorAll('.card__media');

    cardMediaDivs.forEach((cardMedia) => {
      // remove old badge
      const oldBadge = cardMedia.querySelector('.wash-price-badge');
      if (oldBadge) oldBadge.remove();

      // read both metafields
      const wash5 = cardMedia.dataset.wash5;
      const wash4 = cardMedia.dataset.wash4;

      // choose wash5 if available, else wash4
      const washPrice = wash5 && wash5.trim() !== "" ? wash5 : wash4 && wash4.trim() !== "" ? wash4 : null;

      // skip if none
      if (!washPrice) return;

      // create new badge
      const badge = document.createElement('div');
      badge.className = 'wash-price-badge-collection';
      badge.textContent = "Pris per vask ned til " + washPrice;

      // ensure relative positioning
      cardMedia.style.position = "relative";
      cardMedia.appendChild(badge);
    });
  }

  // Run everything
  document.addEventListener('DOMContentLoaded', () => {
    setWashPrice();
    addWashBadges();
  });
</script>



