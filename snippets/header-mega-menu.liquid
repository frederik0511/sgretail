<style>
/* ===============================
   DESKTOP HAMBURGER
================================ */

.desktop-hamburger {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  font-family: 'Barlow Condensed';
  font-size: 18px;
  font-weight: 600;
  color: #00514E;
}

.desktop-hamburger span:first-child {
  font-size: 26px;
  line-height: 1;
}

/* Hide on mobile */
@media (max-width: 1024px) {
  .desktop-hamburger {
    display: none;
  }
}

/* ===============================
   MEGA MENU TOGGLE
================================ */

#MegaMenu-Content-5 {
  max-width: 1280px;
  margin: auto;
  border-bottom-right-radius: 20px;
  border-bottom-left-radius: 20px;
  padding: 0 40px;
  position: absolute;
  top: 64px;
  z-index: 50;

  /* Hidden by default */
  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition: all 0.3s ease;
  pointer-events: none;
}

#MegaMenu-Content-5.is-open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  pointer-events: auto;
}

/* ===============================
   MEGA MENU LAYOUT
================================ */

.mega-menu-v2 {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 30px;
  padding: 30px 40px;
}

/* LEFT */
.mega-menu-v2__heading {
  font-weight: 600;
  font-size: 18px;
  margin-bottom: 12px;
  font-family: 'Barlow Condensed';
  color: #00514E;
  margin-top: 0;
}

.mega-menu-v2__links ul {
