      const desktopSlides = parseInt(sliderElement.getAttribute('data-desktop-slides')) || 4;
      const tabletSlides = parseInt(sliderElement.getAttribute('data-tablet-slides')) || 2;
      const mobileSlides = parseInt(sliderElement.getAttribute('data-mobile-slides')) || 1;
      const autoplayEnabled = sliderElement.getAttribute('data-autoplay') === 'true';
      const autoplaySpeed = parseInt(sliderElement.getAttribute('data-autoplay-speed')) || 3000;
