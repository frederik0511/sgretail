<script>
(function() {
  // 💡 Use Intl.NumberFormat for reliable formatting
  const currencySymbol = 'kr'; // Change if needed (e.g. 'ISK', 'DKK', etc.)
  const locale = 'is-IS'; // Icelandic locale gives "4.485 kr"

  function formatMoney(cents) {
    const amount = cents / 100;
    // Format with local thousands separator & no decimals if .00
    const formatted = new Intl.NumberFormat(locale, {
      style: 'currency',
      currency: 'ISK',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0
    }).format(amount);

    // Optional: ensure symbol spacing matches Shopify's style
    return formatted.replace('ISK', currencySymbol).trim();
  }

  function updateSavingsMessage() {
    fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        let totalSavings = 0;
        cart.items.forEach(item => {
          totalSavings += (item.original_line_price - item.final_line_price);
        });

        const formattedSavings = formatMoney(totalSavings);
        console.log('💰 formattedSavings:', formattedSavings);

        setTimeout(() => {
          const wrapper = document.querySelector('#header-savings-wrapper');
          if (!wrapper) return;

          let savingsContainer = wrapper.querySelector('.cart-savings-message');
          if (!savingsContainer) {
            savingsContainer = document.createElement('div');
            savingsContainer.classList.add('cart-savings-message');
            wrapper.appendChild(savingsContainer);
          }

          if (totalSavings > 0 && cart.items.length > 0) {
            savingsContainer.innerHTML = `Du har spart <span style="color:#00514E;opacity:1">${formattedSavings}</span>`;
            savingsContainer.style.display = 'block';
          } else {
            savingsContainer.style.display = 'none';
          }
        }, 800);
      })
      .catch(err => console.error('Savings update error:', err));
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateSavingsMessage();

    const origFetch = window.fetch;
    window.fetch = async (...args) => {
      const res = await origFetch(...args);
      if (args[0].includes('/cart/add') || args[0].includes('/cart/change') || args[0].includes('/cart/update')) {
        setTimeout(updateSavingsMessage, 1000);
      }
      return res;
    };

    document.addEventListener('click', e => {
      if (e.target.closest('[name="add"], .add-to-cart, .product-form__submit, .quick-add__submit')) {
        setTimeout(updateSavingsMessage, 1000);
      }
    });
  });
})();
