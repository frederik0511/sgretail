{% comment %}
  Section: Category-based Product Cards
  Allows merchant to select a collection (category) from Theme Customizer
{% endcomment %}

<section class="fj-category-products page-width">
  {% if section.settings.heading != blank %}
    <h2 class="related-products__heading inline-richtext h2">{{ section.settings.heading }}</h2>
  {% endif %}

  {% assign collection = collections[section.settings.collection] %}

  {% if collection != blank %}
    <div class="fj-products-grid">
      {% for product in collection.products limit: section.settings.products_limit %}
        <div class="fj-product-card">
          <a href="{{ product.url }}" class="fj-product-link">
            <div class="fj-product-image">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 400 | image_tag }}
              {% endif %}
            </div>
            <h3 class="related-product-title">{{ product.title }}</h3>
          </a>

        {% if product.compare_at_price > product.price %}

  {% assign original = product.compare_at_price | divided_by: 100.0 %}
  {% assign sale = product.price | divided_by: 100.0 %}
  {% assign discount_percent = sale | minus: original | divided_by: original | times: -100 %}
  {% assign discount_percent_decimal = discount_percent | round: 2 %}

  <p class="product-price" style="position: relative;">

    <!-- Original Compare-at price -->
    <span style="text-decoration: line-through; color: #5FB3C4;">
      {{
        product.compare_at_price
        | money_without_currency
        | replace: '.', ','
      }} NOK
    </span>

    <!-- Sale price -->
    <span style="color:#00514E; font-weight:bold; margin-left:6px;">
      {{
        product.price
        | money_without_currency
        | replace: '.', ','
      }} NOK
    </span>

    <!-- Discount percentage badge -->
    <span style="
      font-weight:bold;
      margin-left:8px;
      color: #fff;
      position: absolute;
      right: 0;
      background-color: #00514E;
      padding: 5px 10px;
      border-radius: 10px;
      bottom: 230px;
    ">
      {{ discount_percent_decimal | replace: '.', ',' }}%
    </span>

  </p>

{% else %}

  <p class="product-price">
    {{
      product.price
      | money_without_currency
      | replace: '.', ','
    }} NOK
  </p>

{% endif %}

          <product-form class="collectionAddCart custom-add-to-cart" data-section-id="{{ section.id }}">
  {%- form 'product',
    product,
    id: product_form_id,
    class: 'form add-to-cart',
    novalidate: 'novalidate',
    data-type: 'add-to-cart-form'
  -%}
    <input
      type="hidden"
      name="id"
      value="{{ product.selected_or_first_available_variant.id }}"
      class="product-variant-id"
      {% unless product.selected_or_first_available_variant.available %}
        disabled
      {% endunless %}
    >

    <!-- Quantity Container -->
    <div class="quantity-add-container custom-related-product" style="display: flex; gap: 15px; align-items: center; margin-bottom: 15px;flex-direction:row;">
      <!-- Quantity Wrapper -->
      <div class="quantity-wrapper custom-related">
        <button type="button" onclick="decreaseQty(this)" class="quantity-btn minus" style="background-color: #fff; border: none; width: 32px; height: 50px; font-size: 25px; cursor: pointer;">−</button>
        <input 
          type="text" 
          name="quantity" 
          value="1" 
          min="1" 
          class="product__quantity-input" 
          style="width: calc(100% - 56px); text-align: center; border: none; height: 50px; font-size: 18px; font-weight: bold;"
        >
        <button type="button" onclick="increaseQty(this)" class="quantity-btn plus" style="background-color: #fff; border: none; width: 32px; height: 50px; font-size: 25px; cursor: pointer;">+</button>
      </div>

      <!-- Add to Cart Button -->
      <button
        id="{{ product_form_id }}-submit"
        type="submit"
        name="add"
        class="quick-add__submit button button--full-width button--secondary"
        aria-haspopup="dialog"
        aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
        aria-live="polite"
        data-sold-out-message="true"
        {% unless product.selected_or_first_available_variant.available %}
          disabled
        {% endunless %}
      >
        <span>
          {%- if product.selected_or_first_available_variant.available -%}
            Legg i handlekurv
          {%- else -%}
            Utsolgt
          {%- endif -%}
        </span>
        <span class="sold-out-message hidden">
          Utsolgt
        </span>

        {%- render 'loading-spinner' -%}
      </button>
    </div>
  {%- endform -%}
</product-form>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p>Select a collection from the customizer.</p>
  {% endif %}
</section>

<style>
{% comment %} .fj-category-products { padding: 40px 0; } {% endcomment %}
.fj-category-heading { text-align: center; margin-bottom: 30px;margin-top:30px; }
.fj-products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
}
.quantity-wrapper.custom-related {
    flex: 40%;
    height: 50px ! IMPORTANT;
    border-radius: 100px;
}
.fj-category-products {
    {% comment %} padding: 40px 0; {% endcomment %}
    {% comment %} max-width: 1500px; {% endcomment %}
    margin: auto;
}
{% comment %} .fj-product-card {
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  {% comment %} padding: 16px; {% endcomment %}
  text-align: center;
} {% endcomment %}
.fj-product-image img { max-width: 100%; height: auto; }
.fj-product-title { font-size: 16px; margin: 10px 0; }
.fj-product-price { font-weight: 600;margin:0px; }
.fj-add-to-cart {
  background: #0a5c5a;
  color: #fff;
  border: 0;
  padding: 10px 16px;
  border-radius: 20px;
  cursor: pointer;
}
.fj-product-image img {
    border-radius: 12px;
}
.fj-product-image {
    border: 1px solid #00514E;
    border-radius: 12px;
}
a.fj-product-link {
    text-decoration: none;
    text-align: left;
}
h3.related-product-title {
    font-weight: bold;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    height: 47px;
    padding-bottom: 0;
    margin-bottom: 10px;
}




/* ===== Mobile Slider Only ===== */
@media screen and (max-width: 768px) {

  .fj-products-grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 16px;
    padding-bottom: 10px;
    -webkit-overflow-scrolling: touch;
    margin-left: 10px;
  }

  .fj-products-grid::-webkit-scrollbar {
    display: none;
  }

  .fj-product-card {
    flex: 0 0 70%;
    scroll-snap-align: start;
  }
}
@media screen and (max-width: 768px) {
  .fj-products-grid {
    padding-left: 10px;
    padding-right: 10px;
  }
}

</style>

{% schema %}
{
  "name": "Category Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "POPULÆRE FLEKKFRITT COLLECTION"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select category (collection)"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Number of products",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "LÆG I KURV"
    }
  ],
  "presets": [
    {
      "name": "Category Products"
    }
  ]
}
{% endschema %}
