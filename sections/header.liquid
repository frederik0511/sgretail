    Compare-at price savings ((compare_at - price) * quantity)
    {%- endcomment -%}
    {% assign compare_price = item.product.compare_at_price_max %}
    {% assign base_price = item.product.price %}

    {% if compare_price > base_price %}
      {% assign compare_saving_single = compare_price | minus: base_price %}
      {% assign compare_saving_total = compare_saving_single | times: item.quantity %}
    {% else %}
      {% assign compare_saving_total = 0 %}
    {% endif %}

    {%- comment -%}
    Total savings per item
    {%- endcomment -%}
    {% assign total_item_saving = shopify_discount | plus: compare_saving_total %}

    {%- comment -%}
    Add item saving to the global total
    {%- endcomment -%}
    {% assign total_savings = total_savings | plus: total_item_saving %}

  {% endfor %}

