<script>
function calculateBundlePrice(cart) {
  let totalQty = 0;
  let originalTotal = 0;
  let newFinalPrice = 0;
  cart.items.forEach(item => {
    totalQty += item.quantity;
    originalTotal += (item.original_price)*totalQty;
    newFinalPrice += item.final_line_price
  });


  let discount = 0;
  if (totalQty >= 5) discount = 30;
  else if (totalQty === 4) discount = 20;
  else if (totalQty === 3) discount = 15;
  else if (totalQty === 2) discount = 10;

  const box = document.getElementById('bundle-price-box');
  if (!box) return;

  if (discount > 0) {
    const discountedTotal = originalTotal - (originalTotal * discount / 100);
    box.style.display = 'block';

    const oldPriceEl = box.querySelector('.old-price');
    if (oldPriceEl) {
      oldPriceEl.textContent = (originalTotal / 100).toFixed(2) + ' kr';
    }

    const newPriceEl = box.querySelector('.new-price');
    if (newPriceEl) {
      newPriceEl.textContent = (newFinalPrice / 100).toFixed(2) + ' kr';
    }

    const discountTextEl = box.querySelector('.discount-text');
    if (discountTextEl) {
      discountTextEl.textContent = `(${discount}% OFF)`;
    }

  } else {
    box.style.display = 'none';
  }
}

