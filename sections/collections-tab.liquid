  const instances = {};
  
  function CollectionTabsSlider(sectionId) {
    this.sectionId = sectionId;
    this.sectionElement = document.querySelector(`[data-section-id="${sectionId}"]`);
    this.tabButtons = this.sectionElement.querySelectorAll('.collection-tabs__nav-item');
    this.tabPanes = this.sectionElement.querySelectorAll('.collection-tabs__pane');
    this.swiperInstances = {};
    
    this.init();
