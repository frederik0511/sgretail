    function setActiveSwatch(variantId) {
      variantSelectors.forEach(el => {
        el.classList.toggle('active', el.dataset.variantId === variantId);
      });
    }

    variantSelectors.forEach(swatch => {
      swatch.addEventListener('click', function () {
        const selectedVariantId = this.dataset.variantId;

        // Update Shopify hidden input
        if (variantSelect) {
          variantSelect.value = selectedVariantId;
          variantSelect.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // Visually highlight the selected swatch
        setActiveSwatch(selectedVariantId);
      });
    });

    // Set initial active state
    if (variantSelect) {
      setActiveSwatch(variantSelect.value);
    }
  });
</script>

        
